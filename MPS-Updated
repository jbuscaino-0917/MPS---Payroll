      adjValRows.forEach(r=>avAoa.push([r.empId,r.empName,r.masterName||'-',r.adjName,r.instrAmt,r.importAmt,r.regAmt,r.variance,r.status]));
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(avAoa),'Adjustment Validation');
    }
  }

  // ── ATTENDANCE VALIDATION ──
  if(exportData.currRegWB){
    const attValRows=buildAttendanceValidation(exportData.instrWB,exportData.attendWB,exportData.masterWB,exportData.currRegWB);
    if(attValRows.length>0){
      const attAoa=[];
      attAoa.push([meta]);
      attAoa.push([]);
      // Convert decimal hours to HH:MM string for display
      const toHHMM=(v)=>{
        if(v===''||v===null||v===undefined)return'';
        const n=parseFloat(v);
        if(isNaN(n))return String(v);
        const sign=n<0?'-':'';
        const abs=Math.abs(n);
        const h=Math.floor(abs);
        const m=Math.round((abs-h)*60);
        return sign+String(h).padStart(2,'0')+':'+String(m).padStart(2,'0');
      };
      // For variance: show signed HH:MM (e.g. +00:30 or -01:00), blank if zero or empty
      const toVarHHMM=(v)=>{
        if(v===''||v===null||v===undefined)return'';
        const n=parseFloat(v);
        if(isNaN(n)||n===0)return'';
        const sign=n>0?'+':'-';
        const abs=Math.abs(n);
        const h=Math.floor(abs);
        const m=Math.round((abs-h)*60);
        return sign+String(h).padStart(2,'0')+':'+String(m).padStart(2,'0');
      };
      attAoa.push(['Employee ID','Employee Name','OT Type','Instructions (HH:MM)','Payroll Register (HH:MM)','Variance','Status']);
      // Days Absent stays as days, Minutes Late stays as minutes — only OT uses HH:MM
      const isNonHHMM=(otType)=>{
        const l=(otType||'').toLowerCase();
        return l.includes('absent')||l.includes('late')||l.includes('undertime');
      };
      const fmtVal=(v,otType)=>isNonHHMM(otType)?v:toHHMM(v);
      const fmtVar=(v,otType)=>isNonHHMM(otType)?(v===''||v===null||v===undefined||parseFloat(v)===0?'':v):toVarHHMM(v);
      attValRows.forEach(r=>attAoa.push([r.empId,r.empName,r.otType,fmtVal(r.instrHrs,r.otType),fmtVal(r.regHrs,r.otType),fmtVar(r.instrVsReg,r.otType),r.status]));
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(attAoa),'Attendance Validation');
    }
  }

  // ── RECURRING & LOANS VALIDATION ──
  if((exportData.adjsumWB||exportData.recurringAdjWB)&&exportData.instrWB){
    const rlResult=buildRecurringLoansValidation(exportData.instrWB,exportData.adjsumWB,exportData.masterWB,exportData.currRegWB,exportData.recurringAdjWB);

    // Recurring sheet
    if(rlResult.recurring.length>0){
      const recAoa=[];
      recAoa.push([meta]);recAoa.push([]);
      recAoa.push(['Employee ID','Employee Name','Allowance Name','Frequency','Instructions Amount','Adj Summary Amount','Payroll Register Amount','Variance (Summary vs Reg)','Status']);
      rlResult.recurring.forEach(r=>recAoa.push([r.empId,r.empName,r.name,r.frequency,r.instrAmt,r.summaryAmt,r.regAmt,r.variance,r.status]));
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(recAoa),'Recurring Validation');
    }

    // Loans sheet
    // Only export Loans Validation if instructions actually have loan entries
    const hasInstrLoans=rlResult.loans.some(r=>r.subSection&&r.subSection!=='-'&&r.instrAmt!=='');
    if(rlResult.loans.length>0&&hasInstrLoans){
      const loanAoa=[];
      loanAoa.push([meta]);loanAoa.push([]);
      loanAoa.push(['Employee ID','Employee Name','Loan Type','Sub-section','Instructions Amount','Adj Summary Amount','Payroll Register Amount','Variance (Summary vs Reg)','Status']);
      rlResult.loans.forEach(r=>loanAoa.push([r.empId,r.empName,r.loanType,r.subSection,r.instrAmt,r.summaryAmt,r.regAmt,r.variance,r.status]));
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(loanAoa),'Loans Validation');
    }
  }

  // ── LOAN VALIDATION SUMMARY SHEET ──
  if(exportData.loansumWB){
    const loanValRows=buildLoanValidation(exportData.loansumWB,exportData.currRegWB,exportData.pWB);
    if(loanValRows.length>0){
      const lAoa=[];
      lAoa.push([meta]);lAoa.push([]);
      lAoa.push(['Employee ID','Employee Name','Loan Type','Divided Per Period','Apply Period','Expected Deduction','Register Amount','Variance','Remaining Balance','Status']);
      loanValRows.forEach(r=>lAoa.push([
        r.empId,r.empName,r.adjName,
        r.divPeriod==='yes'?'Yes':'No',
        r.applyPeriod||0,
        r.expectedAmt!==null?r.expectedAmt:'',
        r.regAmt!==''?r.regAmt:'',
        r.variance!==''?r.variance:'',
        r.remBal!==null?r.remBal:'',
        r.status
      ]));
      XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(lAoa),'Loan Validation');
    }
  }

  XLSX.writeFile(wb,fn);
  }catch(err){console.error('Export error:',err);alert('Export failed: '+err.message);}
}

// ─── ADJUSTMENT VALIDATION LOGIC ──────────────────────────
function buildAdjValidation(instrWB, masterWB, adjWB, currRegWB){
  const n2=s=>String(s==null?'':s).trim();
  const nl=s=>n2(s).toLowerCase();
  const normAdj=s=>nl(s).replace(/\s*\(less\)\s*/gi,'').replace(/[^a-z0-9]/g,'');

  // ── 1. Build masterfile ID set ──
  const masterIDs=new Map(); // id -> name
  for(const sn of masterWB.SheetNames){
    if(skipTab(sn))continue;
    const ws=masterWB.Sheets[sn];
    if(!ws||!ws['!ref'])continue;
    const hr=findHdr(ws,ID_KEYS);
    if(hr<0)continue;
    const{headers,rows}=sheetRows(ws,hr);
    const ic=findIdCol(headers);
    const nc=findNameCol(headers);
    if(!ic)continue;
    rows.forEach(r=>{
      const id=n2(r[ic]);
      if(!id||id.length<2)return;
      if(ID_KEYS.some(k=>nl(id)===k))return;
      if(!masterIDs.has(id))masterIDs.set(id,nc?n2(r[nc]):'\u2014');
    });
  }

  // ── 1b. Build register adj map — empId|normAdjName -> amount ──
  // Register shows deductions as POSITIVE with (LESS) in column name
  const regAdjMap=new Map();
  if(currRegWB){
    for(const sn of currRegWB.SheetNames){
      if(skipTab(sn))continue;
      const ws=currRegWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
      const hr=findHdr(ws,ID_KEYS);if(hr<0)continue;
      const{headers,rows}=sheetRows(ws,hr);
      const ic=findIdCol(headers);if(!ic)continue;
      rows.forEach(r=>{
        const id=n2(r[ic]);if(!id||id.length<2)return;
        if(!/[0-9]/.test(id))return;
        const idl=nl(id);
        if(idl==='sub total'||idl==='total'||idl.startsWith('department')||idl.startsWith('dept'))return;
        headers.forEach(h=>{
          if(!h)return;
          const val=parseFloat(String(r[h]||'').replace(/,/g,''));
          if(!val||isNaN(val)||val===0)return;
          // Strip (LESS) and (hh:mm) before normalizing so it matches adjName keys
          const hClean=h.replace(/[(]less[)]/gi,'').replace(/[(]hh:mm[)]/gi,'').trim();
          const hNorm=normAdj(hClean);
          if(!hNorm)return;
          const key=id+'|'+hNorm;
          regAdjMap.set(key,(regAdjMap.get(key)||0)+val);
        });
      });
    }
  }

  // ── 2. Extract One-Time adjustments from instructions Adjustments sheet ──
  // Map key: empId|normAdjName -> {empId, empName, adjName, amount}
  const instrAdj=new Map();
  for(const sn of instrWB.SheetNames){
    const snl=nl(sn);
    if(!snl.includes('adjust'))continue;
    const ws=instrWB.Sheets[sn];
    if(!ws||!ws['!ref'])continue;
    const range=XLSX.utils.decode_range(ws['!ref']);
    let inOneTime=false;
    let hdr=[],idCol=null,nameCol=null,descCol=null,amtCol=null,addDedCol=null;

    for(let r=range.s.r;r<=range.e.r;r++){
      const raw=[];
      for(let c=range.s.c;c<=range.e.c;c++){
        const cell=ws[XLSX.utils.encode_cell({r,c})];
        raw.push(cell?n2(cell.v):'');
      }
      const nonEmpty=raw.filter(v=>v);
      const first=nonEmpty[0]||'';
      if(!first)continue;

      // Detect section headers
      const fl=nl(first);
      if(fl.includes('one-time')||fl==='one time'||fl==='onetime'){inOneTime=true;hdr=[];idCol=null;continue;}
      if(fl.includes('recurring')||fl.includes('loan')||fl.includes('attendance')){inOneTime=false;continue;}
      if(!inOneTime)continue;

      // Detect column header row
      if(!idCol){
        const potId=findIdCol(raw);
        if(potId){
          hdr=raw;
          idCol=potId;
          // Find description column
          descCol=raw.find(v=>nl(v).includes('description')||nl(v).includes('allowance name')||nl(v).includes('name of'));
          amtCol=raw.find(v=>nl(v).includes('amount')&&!nl(v).includes('monthly'));
          addDedCol=raw.find(v=>nl(v).includes('addition')||nl(v).includes('deduction'));
          nameCol=findNameCol(raw)||raw.find(v=>nl(v).includes('employee name'));
        }
        continue;
      }

      // Data row
      const row={};raw.forEach((v,i)=>{if(hdr[i])row[hdr[i]]=v;});
      const empId=n2(row[idCol]);
      if(!empId||empId.length<2)continue;
      if(ID_KEYS.some(k=>nl(empId)===k))continue;

      let adjName=descCol?n2(row[descCol]):'';
      if(!adjName)continue;
      adjName=adjName.replace(/[(]less[)]/gi,'').trim();

      // If Addition/Deduction = Deduction, tag with (LESS) for register matching
      const addDed=addDedCol?nl(row[addDedCol]):'';
      const isInstrDeduction=addDed.includes('deduction');
      if(isInstrDeduction)adjName=adjName+' (LESS)';

      const rawAmt=amtCol?n2(row[amtCol]):'';
      const amt=parseFloat(String(rawAmt).replace(/,/g,''));
      if(isNaN(amt))continue;

      const empName=nameCol?n2(row[nameCol]):'-';
      const key=empId+'|'+normAdj(adjName);

      if(!instrAdj.has(key)){
        instrAdj.set(key,{empId,empName,adjName,amount:0});
      }
      instrAdj.get(key).amount=parseFloat((instrAdj.get(key).amount+amt).toFixed(2));
    }
  }

  // ── 3. Extract from one-time import file ──
  // Columns: Employee ID, Employee Name, Adjustment Type, Adjustment Name, Adjustment Code, Adjustment Amount
  const importAdj=new Map(); // empId|normAdjName -> {empId, empName, adjName, amount}
  for(const sn of adjWB.SheetNames){
    const ws=adjWB.Sheets[sn];
    if(!ws||!ws['!ref'])continue;
    const range=XLSX.utils.decode_range(ws['!ref']);
    let hdr=[],idCol=null,nameCol2=null,adjNameCol=null,amtCol2=null,divPeriodCol2=null,applyPeriodCol=null;

    for(let r=range.s.r;r<=range.e.r;r++){
      const raw=[];
      for(let c=range.s.c;c<=range.e.c;c++){
        const cell=ws[XLSX.utils.encode_cell({r,c})];
        raw.push(cell?n2(cell.v):'');
      }
      const nonEmpty=raw.filter(v=>v);
      if(!nonEmpty.length)continue;

      // Header row detection
      if(!idCol){
        const potId=raw.find(v=>nl(v).includes('employee id')||nl(v).includes('employeeid')||nl(v).includes('emp id'));
        if(potId){
          hdr=raw;
          idCol=potId;
          nameCol2=raw.find(v=>nl(v).includes('employee name'));
          adjNameCol=raw.find(v=>nl(v).includes('adjustment name'));
          amtCol2=raw.find(v=>nl(v).includes('adjustment amount')||nl(v).includes('amount'));
          divPeriodCol2=raw.find(v=>nl(v).includes('divided per period')||nl(v).includes('divide per period')||nl(v).includes('amount will be divided'));
          applyPeriodCol=raw.find(v=>nl(v).includes('apply period')||nl(v).includes('applyperiod'));
        }
        continue;
      }

      const row={};raw.forEach((v,i)=>{if(hdr[i])row[hdr[i]]=v;});
      const empId=n2(row[idCol]);
      if(!empId||empId.length<2)continue;
      // Skip sample/header rows
      if(nl(empId).includes('sample')||nl(empId).includes('employee'))continue;

      let adjName=adjNameCol?n2(row[adjNameCol]):'';
      if(!adjName)continue;
      // Strip (LESS) suffix from adj name so it matches instructions
      adjName=adjName.replace(/\s*\(less\)\s*$/i,'').trim();

      const rawAmt=amtCol2?n2(row[amtCol2]):'';
      let amt=parseFloat(String(rawAmt).replace(/,/g,''));
      if(isNaN(amt))continue;
      // Apply period logic:
      // - If "Amount will be divided per Period" = Yes → divide by 2 (spread across both periods)
      // - If "Apply Period (1-2)" = 1 or 2 → use amount as-is (already for that specific period)
      // - Otherwise use amount as-is
      if(divPeriodCol2&&applyPeriodCol){
        const divVal=nl(n2(row[divPeriodCol2]||''));
        const applyPeriod=n2(row[applyPeriodCol]||'').trim();
        if(divVal==='yes'||divVal==='y'){
          // Divided per period — divide by 2
          amt=parseFloat((amt/2).toFixed(2));
        }
        // If Apply Period = 1 or 2, amount is already per-period, use as-is
      } else if(divPeriodCol2){
        const divVal=nl(n2(row[divPeriodCol2]||''));
        if(divVal==='yes'||divVal==='y')amt=parseFloat((amt/2).toFixed(2));
      }

      const empName=nameCol2?n2(row[nameCol2]):'\u2014';
      const key=empId+'|'+normAdj(adjName);

      if(!importAdj.has(key)){
        importAdj.set(key,{empId,empName,adjName,amount:0,isDeduction:amt<0});
      }
      importAdj.get(key).amount=parseFloat((importAdj.get(key).amount+amt).toFixed(2));
      if(amt<0)importAdj.get(key).isDeduction=true;
    }
  }

  // ── 4. Three-way cross-check: Instructions x Import One-Time x Payroll Register ──
  const normName=s=>nl(s).replace(/[^a-z]/g,'');
  const results=[];
  const allKeys=new Set([...instrAdj.keys(),...importAdj.keys()]);

  for(const key of allKeys){
    const instr=instrAdj.get(key);
    const imp=importAdj.get(key);
    const empId=(instr||imp).empId;
    const empName=(instr&&instr.empName&&instr.empName!=='-')?instr.empName:
                  (imp&&imp.empName&&imp.empName!=='-')?imp.empName:
                  masterIDs.get(empId)||'-';
    const adjName=(instr&&instr.adjName)||(imp&&imp.adjName)||'';
    const masterName=masterIDs.get(empId)||'-';
    const inMaster=masterIDs.has(empId);

    // Amounts
    const instrAmt=instr?instr.amount:'';
    const rawImpAmt=imp?imp.amount:'';
    // Import file: negative = deduction → abs value; register column has (LESS)
    const importAmt=rawImpAmt!==''?Math.abs(rawImpAmt):'';

    // Register lookup using normalized base name (no LESS)
    const adjNameNorm=normAdj(adjName);
    const regAmt=regAdjMap.get(empId+'|'+adjNameNorm)||'';

    const hasInstr=instrAmt!=='';
    const hasImp=importAmt!=='';
    const hasReg=regAmt!=='';

    // Compare import amount vs register (import is the expected amount in register)
    // If no import, compare instructions vs register
    const compareAmt=hasImp?parseFloat(importAmt):parseFloat(instrAmt);

    let status,variance='';
    if(!inMaster){
      status='ID NOT IN MASTERFILE';
    } else if(hasInstr&&hasImp&&hasReg){
      variance=parseFloat((parseFloat(regAmt)-parseFloat(importAmt)).toFixed(2));
      status=variance===0?'MATCHED':'AMOUNT MISMATCH';
    } else if(hasInstr&&hasImp&&!hasReg){
      status='NOT FOUND IN REGISTER';
    } else if(hasInstr&&!hasImp&&hasReg){
      variance=parseFloat((parseFloat(regAmt)-parseFloat(instrAmt)).toFixed(2));
      status=variance===0?'MATCHED':'MISSING FROM IMPORT ONE-TIME';
    } else if(hasInstr&&!hasImp&&!hasReg){
      status='MISSING FROM PAYROLL REGISTER';
    } else if(!hasInstr&&hasImp&&hasReg){
      variance=parseFloat((parseFloat(regAmt)-parseFloat(importAmt)).toFixed(2));
      status='NOT IN INSTRUCTION';
    } else if(!hasInstr&&hasImp&&!hasReg){
      status='NOT IN INSTRUCTION';
    } else {
      status='MISSING FROM INSTRUCTION';
    }

    results.push({empId,empName,masterName,adjName,instrAmt,importAmt,regAmt,variance,status});
  }

  const statusOrder={
    'ID NOT IN MASTERFILE':0,
    'NOT FOUND IN REGISTER':1,
    'MISSING FROM PAYROLL REGISTER':2,
    'NOT IN INSTRUCTION':3,
    'MISSING FROM INSTRUCTION':4,
    'MISSING FROM IMPORT ONE-TIME':5,
    'AMOUNT MISMATCH':6,
    'MATCHED':7
  };
  results.sort((a,b)=>{
    const so=((statusOrder[a.status]!==undefined?statusOrder[a.status]:6))-((statusOrder[b.status]!==undefined?statusOrder[b.status]:6));
    if(so!==0)return so;
    return String(a.empId).localeCompare(String(b.empId),undefined,{numeric:true});
  });

  return results;
}

// ─── ATTENDANCE VALIDATION LOGIC ──────────────────────────
function buildAttendanceValidation(instrWB, attendWB, masterWB, currRegWB){
  const n2=s=>String(s==null?'':s).trim();
  const nl=s=>n2(s).toLowerCase();

  // ── HH:MM to decimal hours ──
  const hhmmToHrs=(v)=>{
    const s=String(v||'').trim();
    if(!s||s==='00:00'||s==='0')return 0;
    if(s.includes(':')){
      const parts=s.split(':');
      const h=parseInt(parts[0],10)||0;
      const m=parseInt(parts[1],10)||0;
      return parseFloat((h+m/60).toFixed(4));
    }
    const n=parseFloat(s.replace(/,/g,''));
    return isNaN(n)?0:n;
  };

  // ── Convert instruction number+unit to hours ──
  const toHours=(num,unit,type)=>{
    const n=parseFloat(String(num).replace(/,/g,''));
    if(isNaN(n))return 0;
    const u=nl(unit||'');
    const t=nl(type||'');
    if(t.includes('absent')||t.includes('day'))return n;
    if(t.includes('late')||t.includes('minute'))return n;
    if(u.includes('min'))return parseFloat((n/60).toFixed(4));
    return n;
  };

  // ── OT type normalizer — maps various labels to a canonical key ──
  const canonOT=(s)=>{
    const l=nl(s).replace(/[^a-z0-9]/g,'');
    const MAP={
      'ordot':'Ord-OT','ordnd':'Ord-ND','ordndot':'Ord-ND-OT',
      'rd':'RD','rdot':'RD-OT','rdnd':'RD-ND','rdndot':'RD-ND-OT',
      'sh':'SH','shot':'SH-OT','shnd':'SH-ND','shndot':'SH-ND-OT',
      'lh':'LH','lhot':'LH-OT','lhnd':'LH-ND','lhndot':'LH-ND-OT',
      'shrd':'SH-RD','shrdot':'SH-RD-OT','shrdnd':'SH-RD-ND','shrdndot':'SH-RD-ND-OT',
      'lhrd':'LH-RD','lhrdot':'LH-RD-OT','lhrdnd':'LH-RD-ND','lhrdndot':'LH-RD-ND-OT',
      'dh':'DH','dhot':'DH-OT','dhnd':'DH-ND','dhndot':'DH-ND-OT',
      'dhrd':'DH-RD','dhrdot':'DH-RD-OT','dhrdnd':'DH-RD-ND','dhrdndot':'DH-RD-ND-OT',
      'absent':'Days Absent','daysabsent':'Days Absent','daysabse':'Days Absent','daysabs':'Days Absent',
      'late':'Minutes Late','lateundertime':'Minutes Late','undertime':'Minutes Late',
      'minuteslate':'Minutes Late','minlate':'Minutes Late','minuteslateu':'Minutes Late'
    };
    return MAP[l]||s;
  };

  // ── Register column → canonical OT key ──
  const regColToCanon=(h)=>{
    // Strip (hh:mm) suffix first: "Ord-OT(hh:mm)" -> "Ord-OT"
    const base=h.replace(/\s*\(hh:mm\)/gi,'').trim();
    const l=nl(base).replace(/[^a-z0-9-]/g,'');
    if(l.includes('daysabsent')||l.includes('daysabs'))return 'Days Absent';
    if(l.includes('minuteslate')||l.includes('minlate')||l.includes('undertime'))return 'Minutes Late';
    if(l==='lh')return 'LH-OT';
    return base; // keep as-is for Ord-OT, LH-RD, RD, SH, etc.
  };

  // ── 1. Build masterfile ID set ──
  const masterIDs=new Set();
  if(masterWB){
    for(const sn of masterWB.SheetNames){
      if(skipTab(sn))continue;
      const ws=masterWB.Sheets[sn];
      if(!ws||!ws['!ref'])continue;
      const hr=findHdr(ws,ID_KEYS);if(hr<0)continue;
      const{headers,rows}=sheetRows(ws,hr);
      const ic=findIdCol(headers);if(!ic)continue;
      rows.forEach(r=>{const id=n2(r[ic]);if(id&&id.length>=2)masterIDs.add(id);});
    }
  }

  // ── 2. Extract from instructions Attendance sheet (Current Attendance only) ──
  // instrMap: empId -> Map<canonOTType, hrs>
  // Skip label rows: Sub Total, Total, Department, etc.
  const isLabelRow=(id)=>{
    const l=nl(String(id||''));
    return !l||l.length<2||l==='sub total'||l==='total'||l.startsWith('department')||
           l.startsWith('dept')||/^[a-z \-\/]+$/.test(l);
  };

  const instrMap=new Map();
  if(instrWB){
    for(const sn of instrWB.SheetNames){
      if(skipTab(sn))continue; // scan ALL sheets — attendance can be in Masterfile or Attendance tab
      const ws=instrWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
      const range=XLSX.utils.decode_range(ws['!ref']);
      let inCurrent=false,hdr=[],idCol=null,nameCol=null,detailCol=null,numCol=null,unitCol=null,addDedCol=null;
      for(let r=range.s.r;r<=range.e.r;r++){
        const raw=[];
        for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r,c})];raw.push(cell?n2(cell.v):'');}
        const nonEmpty=raw.filter(v=>v);const first=nonEmpty[0]||'';if(!first)continue;
        const fl=nl(first);
        if(nonEmpty.some(v=>nl(v).includes('current attendance'))){inCurrent=true;hdr=[];idCol=null;continue;}
        if(inCurrent&&(fl.includes('dispute')||fl.includes('previous payout'))){inCurrent=false;continue;}
        if(!inCurrent)continue;
        if(!idCol){
          const potId=findIdCol(raw);
          if(potId){
            hdr=raw;idCol=potId;
            nameCol=findNameCol(raw)||raw.find(v=>nl(v).includes('full name'));
            detailCol=raw.find(v=>nl(v).includes('detail')||nl(v).includes('ex ot'));
            numCol=raw.find(v=>nl(v).replace(/[^a-z]/g,'').startsWith('number')&&!nl(v).includes('employee'));
            unitCol=raw.find(v=>nl(v).includes('unit')||nl(v).includes('days, hrs'));
            addDedCol=raw.find(v=>nl(v).includes('addition')||nl(v).includes('deduction'));
          }
          continue;
        }
        const row={};raw.forEach((v,i)=>{if(hdr[i])row[hdr[i]]=v;});
        const empId=n2(row[idCol]);
        if(!empId||empId.length<2)continue;
        if(ID_KEYS.some(k=>nl(empId)===k))continue;
        if(isLabelRow(empId))continue;
        const detail=detailCol?n2(row[detailCol]):'';
        const num=numCol?n2(row[numCol]):'';
        const unit=unitCol?n2(row[unitCol]):'';
        const addDed=addDedCol?nl(row[addDedCol]):'addition';
        if(!detail||!num)continue;
        const canon=canonOT(detail);
        const hrs=toHours(num,unit,detail);
        const sign=addDed==='deduction'?-1:1;
        const empName=nameCol?n2(row[nameCol]):'\u2014';
        if(!instrMap.has(empId))instrMap.set(empId,{name:empName,types:new Map()});
        const emp=instrMap.get(empId);
        if(emp.name==='\u2014'&&empName!=='\u2014')emp.name=empName;
        emp.types.set(canon,parseFloat(((emp.types.get(canon)||0)+sign*hrs).toFixed(4)));
      }
    }
  }

  // ── 3. Extract from attendance template file (HH:MM wide format) ──
  // attendMap: empId -> Map<canonOTType, hrs>
  const attendMap=new Map();
  if(attendWB){
    for(const sn of attendWB.SheetNames){
      if(skipTab(sn))continue;
      const ws=attendWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
      const range=XLSX.utils.decode_range(ws['!ref']);
      let hdr=[],idCol=null,nameCol=null,otCols=[];
      for(let r=range.s.r;r<=range.e.r;r++){
        const raw=[];
        for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r,c})];raw.push(cell?n2(cell.v):'');}
        const nonEmpty=raw.filter(v=>v);if(!nonEmpty.length)continue;
        if(!idCol){
          const potId=raw.findIndex(v=>nl(v)==='id'||nl(v).includes('employee id')||nl(v).includes('employee no'));
          if(potId>=0){
            hdr=raw;idCol=hdr[potId];
            nameCol=hdr.find(v=>nl(v).includes('name'));
            // Collect all OT type columns (anything after Name)
            const nameIdx=hdr.indexOf(nameCol);
            otCols=hdr.slice(nameIdx+1).filter(h=>h&&!nl(h).includes('days present')&&!nl(h).includes('remark'));
          }
          continue;
        }
        const row={};raw.forEach((v,i)=>{if(hdr[i])row[hdr[i]]=v;});
        const empId=n2(row[idCol]);
        if(!empId||empId.length<2)continue;
        if(nl(empId).includes('sample')||ID_KEYS.some(k=>nl(empId)===k))continue;
        const empName=nameCol?n2(row[nameCol]):'\u2014';
        if(!attendMap.has(empId))attendMap.set(empId,{name:empName,types:new Map()});
        const emp=attendMap.get(empId);
        if(emp.name==='\u2014'&&empName!=='\u2014')emp.name=empName;
        for(const col of otCols){
          const val=n2(row[col]||'');
          if(!val||val==='00:00'||val==='0')continue;
          const hrs=hhmmToHrs(val);
          if(hrs===0)continue;
          const canon=canonOT(col);
          emp.types.set(canon,parseFloat(((emp.types.get(canon)||0)+hrs).toFixed(4)));
        }
      }
    }
  }

  // ── 4. Extract from current payroll register ──
  // regMap: empId -> Map<canonOTType, hrs>
  const regMap=new Map();
  for(const sn of currRegWB.SheetNames){
    if(skipTab(sn))continue;
    const ws=currRegWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
    const hr2=findHdr(ws,ID_KEYS);if(hr2<0)continue;
    const{headers,rows}=sheetRows(ws,hr2);
    const ic=findIdCol(headers);const nc=findNameCol(headers);if(!ic)continue;
    // Prefer hh:mm columns from the register (e.g. Ord-OT(hh:mm), LH(hh:mm), LH-RD(hh:mm))
    // Fall back to decimal columns if hh:mm not found
    const hhmmCols=headers.filter(h=>nl(h).includes('(hh:mm)')||nl(h).includes('hh:mm'));
    const useHHMM=hhmmCols.length>0;
    const otColNames=headers.filter(h=>{
      const hl=nl(h);
      if(useHHMM){
        // Use only hh:mm columns for OT, plus plain numeric cols for absent/late/undertime
        return (hl.includes('(hh:mm)')||hl.includes('hh:mm')||
                hl.includes('days absent')||hl.includes('minutes late')||hl.includes('undertime'))&&
               !hl.includes('total')&&!hl.includes('deduct');
      }
      return (hl==='ord-ot'||hl==='lh'||hl==='lh-rd'||hl==='lh-rd-ot'||hl==='lh-ot'||
              hl==='rd-ot'||hl==='rd'||hl==='sh-ot'||hl==='sh-rd'||hl==='sh'||
              hl==='dh-ot'||hl==='dh-rd'||hl==='dh'||
              hl.includes('days absent')||hl.includes('minutes late')||hl.includes('undertime'))&&
             !hl.includes('hh:mm')&&!hl.includes('total')&&!hl.includes('deduct');
    });
    rows.forEach(r=>{
      const id=n2(r[ic]);if(!id||id.length<2)return;
      if(ID_KEYS.some(k=>nl(id)===k))return;
      if(isLabelRow(id))return;
      const name=nc?n2(r[nc]):'\u2014';
      if(!regMap.has(id))regMap.set(id,{name,types:new Map()});
      const emp=regMap.get(id);
      otColNames.forEach(col=>{
        const raw=n2(r[col]||'');
        if(!raw||raw==='0'||raw==='00:00')return;
        // Parse hh:mm or decimal
        let hrs;
        if(raw.includes(':')){
          hrs=hhmmToHrs(raw);
        } else {
          hrs=parseFloat(raw.replace(/,/g,''));
          if(isNaN(hrs))return;
        }
        if(hrs===0)return;
        const canon=regColToCanon(col);
        emp.types.set(canon,parseFloat(((emp.types.get(canon)||0)+hrs).toFixed(4)));
      });
    });
  }

  // ── 5. Build union of all employee+OT keys across all 3 sources ──
  const allKeys=new Set();
  const addKeys=(map)=>map.forEach((emp,id)=>emp.types.forEach((_,ot)=>allKeys.add(id+'|'+ot)));
  addKeys(instrMap);addKeys(regMap);

  // Also add register entries not in instructions or attend
  regMap.forEach((emp,id)=>emp.types.forEach((_,ot)=>allKeys.add(id+'|'+ot)));

  const results=[];
  const statusOrder={
    'ID NOT IN MASTERFILE':0,
    'MISSING IN REGISTER':1,
    'INSTR vs REG MISMATCH':2,
    'ATTEND vs REG MISMATCH':3,
    'INSTR & ATTEND vs REG MISMATCH':4,
    'INSTR vs ATTEND MISMATCH':5,
    'MISSING IN INSTRUCTIONS':6,
    'MATCHED':7
  };

  for(const key of allKeys){
    const [empId,otType]=key.split('|');
    const instrEmp=instrMap.get(empId);
    const attendEmp=attendMap.get(empId);
    const regEmp=regMap.get(empId);
    const empName=((regEmp||instrEmp||attendEmp)&&(regEmp||instrEmp||attendEmp).name)||'\u2014';
    const inMaster=!(!masterWB||masterIDs.size===0)||masterIDs.has(empId);

    const instrHrs=(instrEmp&&instrEmp.types&&instrEmp.types.get(otType)!==undefined)?instrEmp.types.get(otType):null;
    const attendHrs=(attendEmp&&attendEmp.types&&attendEmp.types.get(otType)!==undefined)?attendEmp.types.get(otType):null;
    const regHrs=(regEmp&&regEmp.types&&regEmp.types.get(otType)!==undefined)?regEmp.types.get(otType):null;

    let status;
    if(!inMaster){
      status='ID NOT IN MASTERFILE';
    } else if(instrHrs!==null&&regHrs===null){
      status='MISSING IN REGISTER';
    } else if(regHrs!==null&&instrHrs===null){
      status='MISSING IN INSTRUCTIONS';
    } else if(instrHrs!==null&&regHrs!==null){
      const variance=parseFloat((regHrs-instrHrs).toFixed(4));
      status=variance===0?'MATCHED':'AMOUNT MISMATCH';
    } else {
      status='MISSING IN INSTRUCTIONS';
    }

    const instrVsReg=(instrHrs!==null&&regHrs!==null)?parseFloat((regHrs-instrHrs).toFixed(4)):'';

    results.push({empId,empName,otType,
      instrHrs:instrHrs!==null?instrHrs:'',
      attendHrs:attendHrs!==null?attendHrs:'',
      regHrs:regHrs!==null?regHrs:'',
      instrVsReg,status});
  }

  results.sort((a,b)=>{
    const so=((statusOrder[a.status]!==undefined?statusOrder[a.status]:9))-((statusOrder[b.status]!==undefined?statusOrder[b.status]:9));
    if(so!==0)return so;
    return String(a.empId).localeCompare(String(b.empId),undefined,{numeric:true});
  });

  return results;
}

// ─── RECURRING & LOANS VALIDATION LOGIC ──────────────────
function buildRecurringLoansValidation(instrWB, adjsumWB, masterWB, currRegWB, recurringAdjWB){
  const n2=s=>String(s==null?'':s).trim();
  const nl=s=>n2(s).toLowerCase();
  const toNum=v=>{const n=parseFloat(String(v||'').replace(/,/g,'').replace(/[()]/g,''));return isNaN(n)?null:Math.abs(n);};
  const normName=s=>nl(s).replace(/[^a-z0-9]/g,'');

  // ── Loan type → payroll register column mapping ──
  const LOAN_COL_MAP={
    'sss calamity loan':'SSS CLOAN (LESS)',
    'ssscalamityloan':'SSS CLOAN (LESS)',
    'sss calamity':'SSS CLOAN (LESS)',
    'ssscalamity':'SSS CLOAN (LESS)',
    'sssl':'SSS CLOAN (LESS)',
    'sss loan':'SSS SLOAN (LESS)',
    'sssloan':'SSS SLOAN (LESS)',
    'hdmf calamity loan':'HDMF CLOAN (LESS)',
    'hdmfcalamityloan':'HDMF CLOAN (LESS)',
    'hdmf calamity':'HDMF CLOAN (LESS)',
    'hdmfcalamity':'HDMF CLOAN (LESS)',
    'hdmfl':'HDMF CLOAN (LESS)',
    'hdmf loan':'HDMF SLOAN (LESS)',
    'hdmfloan':'HDMF SLOAN (LESS)',
    'hdmf salary loan':'HDMF SLOAN (LESS)',
    'hdmfsalaryloan':'HDMF SLOAN (LESS)',
    'sss salary loan':'SSS SLOAN (LESS)',
    'ssssalaryloan':'SSS SLOAN (LESS)',
  };
  const loanToRegCol=(type,code)=>{
    const tk=normName(type||'');
    const ck=normName(code||'');
    return LOAN_COL_MAP[tk]||LOAN_COL_MAP[ck]||null;
  };

  // ── 1. Masterfile IDs ──
  const masterIDs=new Set();
  const masterNames=new Map();
  if(masterWB){
    for(const sn of masterWB.SheetNames){
      if(skipTab(sn))continue;
      const ws=masterWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
      const hr=findHdr(ws,ID_KEYS);if(hr<0)continue;
      const{headers,rows}=sheetRows(ws,hr);
      const ic=findIdCol(headers);const nc=findNameCol(headers);if(!ic)continue;
      rows.forEach(r=>{
        const id=n2(r[ic]);if(!id||id.length<2)return;
        masterIDs.add(id);
        if(nc&&!masterNames.has(id))masterNames.set(id,n2(r[nc]));
      });
    }
  }

  // ── 2. Parse Adjustment Summary Report ──
  // Builds two maps: recurringSum (empId|name -> amt) and loansSum (empId|regCol -> perCutoffAmt)
  const recurringSum=new Map();  // key: empId|normName -> {empId,empName,name,adjType,amount}
  const loansSum=new Map();      // key: empId|regCol   -> {empId,empName,loanType,adjCode,perCutoff}

  // Use recurringAdjWB for recurring if provided, otherwise fall back to adjsumWB
  const recurringSource=recurringAdjWB||adjsumWB;

  if(!adjsumWB&&!recurringSource)return {recurring:[],loans:[]};
  const summaryWB=adjsumWB||recurringSource;
  for(const sn of summaryWB.SheetNames){
    const ws=summaryWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
    const range=XLSX.utils.decode_range(ws['!ref']);
    let hdr=[],idColIdx=-1,adjTypeIdx=-1,adjNameIdx=-1,adjCodeIdx=-1,adjAmtIdx=-1,maxAmtIdx=-1,divPeriodIdx=-1,remainBalIdx=-1,lnIdx=-1,fnIdx=-1;

    for(let r=range.s.r;r<=range.e.r;r++){
      const raw=[];
      for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r,c})];raw.push(cell?n2(cell.v):'');}
      const nonEmpty=raw.filter(v=>v);if(!nonEmpty.length)continue;

      // Header row detection
      if(idColIdx<0){
        const potId=raw.findIndex(v=>nl(v).includes('employee id')||nl(v).includes('employeeid'));
        if(potId>=0){
          hdr=raw;idColIdx=potId;
          adjTypeIdx=raw.findIndex(v=>nl(v).includes('adjustment type'));
          adjNameIdx=raw.findIndex(v=>nl(v).includes('adjustment name'));
          adjCodeIdx=raw.findIndex(v=>nl(v).includes('adjustment code'));
          adjAmtIdx=raw.findIndex(v=>nl(v).includes('adjustment amount'));
          maxAmtIdx=raw.findIndex(v=>nl(v).includes('maximum amount'));
          divPeriodIdx=raw.findIndex(v=>nl(v).includes('divided per period'));
          remainBalIdx=raw.findIndex(v=>nl(v).includes('remaining balance')||nl(v).includes('remainingbalance'));
          lnIdx=raw.findIndex(v=>nl(v)==='last name'||nl(v).includes('last name'));
          fnIdx=raw.findIndex(v=>nl(v)==='first name'||nl(v).includes('first name'));
        }
        continue;
      }

      const empId=raw[idColIdx]||'';if(!empId||empId.length<2)continue;
      // Skip entries where Remaining Balance = 0 (fully paid off)
      if(remainBalIdx>=0){
        const remBal=parseFloat(String(raw[remainBalIdx]||'').replace(/,/g,'').replace(/[()]/g,''));
        if(!isNaN(remBal)&&remBal===0)continue;
      }
      const adjType=adjTypeIdx>=0?raw[adjTypeIdx]:'';
      const adjName=adjNameIdx>=0?raw[adjNameIdx]:'';
      const adjCode=adjCodeIdx>=0?raw[adjCodeIdx]:'';
      const adjAmt=adjAmtIdx>=0?toNum(raw[adjAmtIdx]):null;
      const maxAmt=maxAmtIdx>=0?toNum(raw[maxAmtIdx]):null;
      const divPeriod=divPeriodIdx>=0?nl(raw[divPeriodIdx]):'no';
      const empName=[(lnIdx>=0?raw[lnIdx]:''), (fnIdx>=0?raw[fnIdx]:'')].filter(Boolean).join(', ');

      // Determine per-cutoff amount:
      // If Divided Per Period = Yes, divide by 2; otherwise use full amount
      const perCutoff=adjAmt!==null?(divPeriod==='yes'?parseFloat((adjAmt/2).toFixed(2)):adjAmt):null;

      const adjTypeL=nl(adjType);
      const isLoan=adjTypeL.includes('loan')||adjTypeL.includes('hdmf')||adjTypeL.includes('sss');

      if(isLoan){
        const regCol=loanToRegCol(adjType,adjCode)||loanToRegCol(adjName,adjCode);
        if(regCol){
          const key=empId+'|'+regCol;
          if(!loansSum.has(key))loansSum.set(key,{empId,empName,loanType:adjName||adjType,adjCode,regCol,perCutoff:perCutoff||0});
          else loansSum.get(key).perCutoff=parseFloat(((loansSum.get(key).perCutoff||0)+(perCutoff||0)).toFixed(2));
        }
      } else {
        // Recurring allowance
        const key=empId+'|'+normName(adjName);
        if(!recurringSum.has(key))recurringSum.set(key,{empId,empName,name:adjName,adjType,amount:perCutoff||0});
        else recurringSum.get(key).amount=parseFloat(((recurringSum.get(key).amount||0)+(perCutoff||0)).toFixed(2));
      }
    }
  }

  // ── 3. Parse Payroll Register for recurring and loan columns ──
  const regRecurring=new Map(); // empId|normName -> amount
  const regLoans=new Map();     // empId|regCol   -> amount

  if(currRegWB){
    for(const sn of currRegWB.SheetNames){
      if(skipTab(sn))continue;
      const ws=currRegWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
      const hr=findHdr(ws,ID_KEYS);if(hr<0)continue;
      const{headers,rows}=sheetRows(ws,hr);
      const ic=findIdCol(headers);if(!ic)continue;

      // Loan columns in register
      const loanCols=headers.filter(h=>{
        const hl=nl(h);
        return hl.includes('cloan')||hl.includes('sloan')||hl.includes('loan');
      });

      // Allowance columns (for recurring)
      const allowCols=headers.filter(h=>{
        const hl=nl(h);
        return !hl.includes('deduct')&&!hl.includes('(less)')&&!hl.includes('tax')&&
               !hl.includes('net pay')&&!hl.includes('gross')&&!hl.includes('basic salary')&&
               !hl.includes('total')&&!hl.includes('absent')&&!hl.includes('late')&&
               !hl.includes('sss')&&!hl.includes('philhealth')&&!hl.includes('hdmf')&&
               !hl.includes('withholding')&&!hl.includes('ot')&&!hl.includes('work days')&&
               !hl.includes('bank')&&!hl.includes('gender')&&!hl.includes('employment status')&&
               (hl.includes('allowance')||hl.includes('subsidy')||hl.includes('differential')||
                hl.includes('gas')||hl.includes('meal')||hl.includes('rice')||
                hl.includes('transpo')||hl.includes('internet')||hl.includes('electric')||
                hl.includes('mbo')||hl.includes('rsu')||hl.includes('benefit')||
                hl.includes('bonus')||hl.includes('incentive'));
      });

      rows.forEach(r=>{
        const id=n2(r[ic]);if(!id||id.length<2)return;
        if(ID_KEYS.some(k=>nl(id)===k))return;
        // Skip Sub Total, Total, Department rows
        const idl=nl(id);
        if(idl==='sub total'||idl==='total'||idl.startsWith('department')||idl.startsWith('dept')||/^[a-z\s\-\/]+$/.test(id.trim()))return;

        loanCols.forEach(col=>{
          const val=toNum(r[col]);if(!val)return;
          // Normalize col name to match loansSum keys (e.g. 'SSS SLOAN (LESS)' -> same)
          const colNorm=nl(col);
          let mappedCol=col; // default to raw col name
          if(colNorm.includes('sss')&&colNorm.includes('sloan'))mappedCol='SSS SLOAN (LESS)';
          else if(colNorm.includes('sss')&&colNorm.includes('cloan'))mappedCol='SSS CLOAN (LESS)';
          else if(colNorm.includes('hdmf')&&(colNorm.includes('sloan')||colNorm.includes('salary')))mappedCol='HDMF SLOAN (LESS)';
          else if(colNorm.includes('hdmf')&&(colNorm.includes('cloan')||colNorm.includes('calamity')))mappedCol='HDMF CLOAN (LESS)';
          else if(colNorm.includes('hdmf')&&colNorm.includes('mp2'))mappedCol='HDMF MP2 (LESS)';
          else if(colNorm.includes('sss')&&colNorm.includes('condon'))mappedCol='SSS SLOAN (CONDONATION) (LESS)';
          const key=id+'|'+mappedCol;
          regLoans.set(key,(regLoans.get(key)||0)+val);
        });

        allowCols.forEach(col=>{
          const val=toNum(r[col]);if(!val)return;
          const key=id+'|'+normName(col);
          regRecurring.set(key,(regRecurring.get(key)||0)+val);
        });
      });
    }
  }

  // ── 4. Parse Instructions — Recurring and Loans sections ──
  const instrRecurring=new Map(); // empId|normName -> {empId,empName,name,frequency,amount}
  const instrLoans=new Map();     // empId|regCol   -> {empId,empName,loanType,subSection,amount}

  if(instrWB){
    for(const sn of instrWB.SheetNames){
      if(skipTab(sn))continue;
      const ws=instrWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
      const range=XLSX.utils.decode_range(ws['!ref']);
      const snl=nl(sn);
      const isAdjSheet=snl.includes('adjust');
      const isLoanSheet=snl.includes('loan');
      if(!isAdjSheet&&!isLoanSheet)continue;

      let mode=null,hdr=[],idCol=null;

      for(let r=range.s.r;r<=range.e.r;r++){
        const raw=[];
        for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r,c})];raw.push(cell?n2(cell.v):'');}
        const nonEmpty=raw.filter(v=>v);const first=nonEmpty[0]||'';if(!first)continue;
        const fl=nl(first);

        // Section detection
        if(fl==='recurring'||nonEmpty.some(v=>nl(v)==='recurring')){mode='recurring';hdr=[];idCol=null;continue;}
        if(fl.includes('new loan')){mode='new_loan';hdr=[];idCol=null;continue;}
        if(fl.includes('stop deduction')){mode='stop_loan';hdr=[];idCol=null;continue;}
        if(fl.includes('for adjustment')){mode='adj_loan';hdr=[];idCol=null;continue;}
        if(fl.includes('one-time')||fl==='one time'){mode=null;continue;}
        if(!mode)continue;

        // Column header row
        if(!idCol){
          const potId=findIdCol(raw);
          if(potId){hdr=raw;idCol=potId;}
          continue;
        }

        const row={};raw.forEach((v,i)=>{if(hdr[i])row[hdr[i]]=v;});
        const empId=n2(row[idCol]);
        if(!empId||empId.length<2)continue;
        if(ID_KEYS.some(k=>nl(empId)===k))continue;
        const empName=findNameCol(hdr)?n2(row[findNameCol(hdr)]||''):'\u2014';

        if(mode==='recurring'){
          const descCol=hdr.find(h=>nl(h).includes('description')||nl(h).includes('allowance'));
          const amtCol=hdr.find(h=>nl(h).includes('monthly amount')||nl(h).includes('per cut'));
          const freqCol=hdr.find(h=>nl(h).includes('recurring')||nl(h).includes('frequency')||nl(h).includes('1st'));
          const name=descCol?n2(row[descCol]):'';if(!name)continue;
          const amt=amtCol?toNum(row[amtCol]):null;if(amt===null)continue;
          const freq=freqCol?n2(row[freqCol]):'';
          const key=empId+'|'+normName(name);
          if(!instrRecurring.has(key))instrRecurring.set(key,{empId,empName,name,frequency:freq,amount:amt});
          else instrRecurring.get(key).amount=parseFloat(((instrRecurring.get(key).amount)+amt).toFixed(2));
        }

        if(mode==='new_loan'||mode==='stop_loan'||mode==='adj_loan'){
          const loanTypeCol=hdr.find(h=>nl(h).includes('loan type')||nl(h).includes('loan description'));
          const amtCol=mode==='adj_loan'
            ?hdr.find(h=>nl(h).includes('new monthly'))
            :mode==='stop_loan'
              ?hdr.find(h=>nl(h).includes('monthly loan'))
              :hdr.find(h=>nl(h).includes('per cut off')||nl(h).includes('per cutoff'));
          const loanType=loanTypeCol?n2(row[loanTypeCol]):'';if(!loanType)continue;
          const regCol=loanToRegCol(loanType,'');if(!regCol)continue;
          const amt=amtCol?toNum(row[amtCol]):null;
          const subLabel=mode==='new_loan'?'New Loan':mode==='stop_loan'?'Stop Deduction':'For Adjustment';
          const key=empId+'|'+regCol;
          if(!instrLoans.has(key))instrLoans.set(key,{empId,empName,loanType,subSection:subLabel,amount:mode==='stop_loan'?0:amt});
        }
      }
    }
  }

  // ── 5. Cross-check Recurring ──
  const recurringResults=[];
  const statusOrder={'ID NOT IN MASTERFILE':0,'MISSING IN REGISTER':1,'MISSING IN ADJ SUMMARY':2,'AMOUNT MISMATCH':3,'MISSING IN INSTRUCTIONS':4,'MATCHED':5};
  const allRecKeys=new Set([...instrRecurring.keys(),...recurringSum.keys()]);

  for(const key of allRecKeys){
    const instr=instrRecurring.get(key);
    const summ=recurringSum.get(key);
    const empId=(instr||summ).empId;
    let empName=(instr&&instr.empName&&instr.empName!=='-')?instr.empName:
                (summ&&summ.empName&&summ.empName!=='-')?summ.empName:
                masterNames.get(empId)||'-';
    const name=(instr||summ).name;
    const inMaster=!masterWB||masterIDs.has(empId);

    const instrAmt=instr?instr.amount:'';
    const summAmt=summ?summ.amount:'';
    const nameNorm=normName(name);
    let regAmt='';
    const exactKey=empId+'|'+nameNorm;
    if(regRecurring.has(exactKey)){
      regAmt=regRecurring.get(exactKey);
    } else {
      for(const [rk,rv] of regRecurring){
        const [rid,rname]=rk.split('|');
        if(rid===empId&&(rname.includes(nameNorm)||nameNorm.includes(rname)||(nameNorm.length>4&&rname.includes(nameNorm.slice(0,5))))){
          regAmt=rv;break;
        }
      }
    }

    let variance='',status;
    if(!inMaster){status='ID NOT IN MASTERFILE';}
    else if(summAmt!==''&&regAmt!==''){
      variance=parseFloat((regAmt-summAmt).toFixed(2));
      status=variance===0?'MATCHED':'AMOUNT MISMATCH';
    } else if(summAmt!==''&&regAmt===''){status='MISSING IN REGISTER';}
    else if(instrAmt!==''&&summAmt===''){status='MISSING IN ADJ SUMMARY';}
    else {status='MISSING IN INSTRUCTIONS';}

    recurringResults.push({empId,empName,name:name||'\u2014',frequency:(instr&&instr.frequency)||'',instrAmt,summaryAmt:summAmt,regAmt,variance,status});
  }
  // Exclude terminated employees
  const terminatedIds=new Set();
  if(masterWB){
    for(const sn of masterWB.SheetNames){
      if(skipTab(sn))continue;
      const wsT=masterWB.Sheets[sn];if(!wsT||!wsT['!ref'])continue;
      const hrT=findHdr(wsT,ID_KEYS);if(hrT<0)continue;
      const{headers:mhT,rows:mrT}=sheetRows(wsT,hrT);
      const icT=findIdCol(mhT);
      const scT=mhT.find(h=>normL(h).includes('employment status'));
      if(!icT||!scT)continue;
      mrT.forEach(r=>{
        const id=n2(r[icT]);
        const st=normL(n2(r[scT]||''));
        if(id&&(st.includes('terminat')||st.includes('separated')||st.includes('resigned')))terminatedIds.add(id);
      });
    }
  }
  const filteredRecurring=recurringResults.filter(r=>!terminatedIds.has(r.empId));
  filteredRecurring.sort((a,b)=>{
    const so=((statusOrder[a.status]!==undefined?statusOrder[a.status]:6))-((statusOrder[b.status]!==undefined?statusOrder[b.status]:6));
    return so!==0?so:String(a.empId).localeCompare(String(b.empId),undefined,{numeric:true});
  });

  // ── 6. Cross-check Loans ──
  const loansResults=[];
  const loanStatusOrder={'ID NOT IN MASTERFILE':0,'SHOULD BE ZERO — STILL DEDUCTING':1,'MISSING IN REGISTER':2,'MISSING IN ADJ SUMMARY':3,'AMOUNT MISMATCH':4,'MISSING IN INSTRUCTIONS':5,'MATCHED':6};
  const allLoanKeys=new Set([...instrLoans.keys(),...loansSum.keys()]);
  // Also add register loan entries
  regLoans.forEach((_,k)=>allLoanKeys.add(k));

  for(const key of allLoanKeys){
    const instr=instrLoans.get(key);
    const summ=loansSum.get(key);
    const [empId,regCol]=key.split('|');
    const empName=((instr||summ)&&(instr||summ).empName)||masterNames.get(empId)||'\u2014';
    const loanType=((instr||summ)&&(instr||summ).loanType)||regCol;
    const subSection=(instr&&instr.subSection)||'\u2014';
    const inMaster=!masterWB||masterIDs.has(empId);

    const instrAmt=instr?instr.amount:'';
    const summAmt=summ?summ.perCutoff:'';
    const regAmt=regLoans.get(key)||'';

    let variance='',status;
    if(!inMaster){status='ID NOT IN MASTERFILE';}
    else if((instr&&instr.subSection)==='Stop Deduction'){
      status=regAmt!==''&&regAmt>0?'SHOULD BE ZERO — STILL DEDUCTING':'MATCHED';
      variance=regAmt!==''?regAmt:'';
    } else if(summAmt!==''&&regAmt!==''){
      variance=parseFloat((regAmt-summAmt).toFixed(2));
      status=variance===0?'MATCHED':'AMOUNT MISMATCH';
    } else if(summAmt!==''&&regAmt===''){status='MISSING IN REGISTER';}
    else if(instrAmt!==''&&summAmt===''){status='MISSING IN ADJ SUMMARY';}
    else if(regAmt!==''&&instrAmt===''&&summAmt===''){status='MISSING IN INSTRUCTIONS';}
    else {status='MATCHED';}

    loansResults.push({empId,empName,loanType,subSection,instrAmt,summaryAmt:summAmt,regAmt,variance,status});
  }
  loansResults.sort((a,b)=>{
    const so=((loanStatusOrder[a.status]!==undefined?loanStatusOrder[a.status]:7))-((loanStatusOrder[b.status]!==undefined?loanStatusOrder[b.status]:7));
    return so!==0?so:String(a.empId).localeCompare(String(b.empId),undefined,{numeric:true});
  });

  return {recurring:filteredRecurring,loans:loansResults};
}
// ─── LOAN VALIDATION (Adjustment Summary × Payroll Register) ──────────────
function buildLoanValidation(loansumWB, currRegWB, prevRegWB){
  if(!loansumWB) return [];
  const n2=s=>String(s==null?'':s).trim();
  const nl=s=>n2(s).toLowerCase();
  const toNum=v=>{const n=parseFloat(String(v||'').replace(/,/g,'').replace(/[()]/g,''));return isNaN(n)?null:Math.abs(n);};
  const normName=s=>nl(s).replace(/[^a-z0-9]/g,'');

  // ── Determine current cutoff number (1 or 2) from current register filename/sheet ──
  // We infer from the previous register: if prev is cutoff 1, current is cutoff 2 and vice versa.
  // Default to cutoff 2 if we can't determine.
  let currentCutoff=2;
  if(currRegWB){
    for(const sn of currRegWB.SheetNames){
      const snl=nl(sn);
      if(snl.includes('cutoff 1')||snl.includes('cut-off 1')||snl.includes('1st cutoff')||snl.match(/[-_ ]1$/))
        {currentCutoff=1;break;}
      if(snl.includes('cutoff 2')||snl.includes('cut-off 2')||snl.includes('2nd cutoff')||snl.match(/[-_ ]2$/))
        {currentCutoff=2;break;}
    }
  }

  // ── LOAN_COL_MAP: Loan type/code → register column header ──
  const LOAN_COL_MAP={
    'ssssalaryloan':'SSS SLOAN (LESS)','sssloan':'SSS SLOAN (LESS)','sssln':'SSS SLOAN (LESS)',
    'ssscalamityloan':'SSS CLOAN (LESS)','ssscalamity':'SSS CLOAN (LESS)','ssscal':'SSS CLOAN (LESS)',
    'hdmfsalaryloan':'HDMF SLOAN (LESS)','hdmfloan':'HDMF SLOAN (LESS)','hdmfsl':'HDMF SLOAN (LESS)',
    'hdmfcalamityloan':'HDMF CLOAN (LESS)','hdmfcalamity':'HDMF CLOAN (LESS)','hdmfc':'HDMF CLOAN (LESS)',
  };
  const loanToRegCol=(name,code)=>{
    const nk=normName(name||'');
    const ck=normName(code||'');
    return LOAN_COL_MAP[nk]||LOAN_COL_MAP[ck]||null;
  };

  // ── 1. Parse Adjustment Summary Sheet ──
  const results=[];
  for(const sn of loansumWB.SheetNames){
    const ws=loansumWB.Sheets[sn];if(!ws||!ws['!ref'])continue;
    const range=XLSX.utils.decode_range(ws['!ref']);
    let hdr=[],idIdx=-1,lnIdx=-1,fnIdx=-1,adjTypeIdx=-1,adjNameIdx=-1,adjCodeIdx=-1,
        adjAmtIdx=-1,remBalIdx=-1,divPeriodIdx=-1,applyPeriodIdx=-1;

    for(let r=range.s.r;r<=range.e.r;r++){
      const raw=[];
      for(let c=range.s.c;c<=range.e.c;c++){
        const cell=ws[XLSX.utils.encode_cell({r,c})];
        raw.push(cell?n2(cell.v):'');
      }
      if(!raw.some(v=>v))continue;

      // Header row detection
      if(idIdx<0){
        const potId=raw.findIndex(v=>nl(v).includes('employee id')||nl(v)==='employeeid'||nl(v).includes('emp id'));
        if(potId>=0){
          hdr=raw; idIdx=potId;
          lnIdx=raw.findIndex(v=>nl(v)==='last name'||nl(v).includes('last name'));
          fnIdx=raw.findIndex(v=>nl(v)==='first name'||nl(v).includes('first name'));
          adjTypeIdx=raw.findIndex(v=>nl(v).includes('adjustment type'));
          adjNameIdx=raw.findIndex(v=>nl(v).includes('adjustment name'));
          adjCodeIdx=raw.findIndex(v=>nl(v).includes('adjustment code'));
          adjAmtIdx=raw.findIndex(v=>nl(v).includes('adjustment amount'));
          remBalIdx=raw.findIndex(v=>nl(v).includes('remaining balance'));
          divPeriodIdx=raw.findIndex(v=>nl(v).includes('divided per period'));
          applyPeriodIdx=raw.findIndex(v=>nl(v).includes('apply period'));
        }
        continue;
      }

      const empId=n2(raw[idIdx]);if(!empId||empId.length<2)continue;
      const empName=[(lnIdx>=0?raw[lnIdx]:''),(fnIdx>=0?raw[fnIdx]:'')].filter(Boolean).join(', ');
      const adjType=adjTypeIdx>=0?raw[adjTypeIdx]:'';
      const adjName=adjNameIdx>=0?raw[adjNameIdx]:'';
      const adjCode=adjCodeIdx>=0?raw[adjCodeIdx]:'';

      // Only process loan types
      const adjTypeL=nl(adjType);
      const isLoan=adjTypeL.includes('loan')||adjTypeL.includes('hdmf')||adjTypeL.includes('sss');
      if(!isLoan)continue;

      const adjAmt=adjAmtIdx>=0?toNum(raw[adjAmtIdx]):null;
      const remBal=remBalIdx>=0?parseFloat(String(raw[remBalIdx]||'').replace(/,/g,'').replace(/[()]/g,'')):null;
      const divPeriod=divPeriodIdx>=0?nl(raw[divPeriodIdx]):'no';
      const applyPeriod=applyPeriodIdx>=0?parseInt(String(raw[applyPeriodIdx]||'0'),10):0;

      const regCol=loanToRegCol(adjName,adjCode)||loanToRegCol(adjType,adjCode);
      if(!regCol)continue;

      // ── Determine if this loan applies this cutoff ──
      let appliesToCutoff=false;
      let expectedAmt=null;
      let skipReason='';

      if(!isNaN(remBal)&&remBal===0){
        // Fully paid off
        skipReason='COMPLETED — FULLY PAID';
      } else if(divPeriod==='yes'){
        // Divided per period: deduct every cutoff, amount = adj_amount / 2
        appliesToCutoff=true;
        expectedAmt=adjAmt!==null?parseFloat((adjAmt/2).toFixed(2)):null;
      } else {
        // Not divided: apply only on the specific cutoff number
        if(applyPeriod===0||applyPeriod===currentCutoff){
          appliesToCutoff=true;
          expectedAmt=adjAmt;
        } else {
          skipReason=`NOT APPLICABLE — APPLY PERIOD ${applyPeriod} (CURRENT: ${currentCutoff})`;
        }
      }

      results.push({
        empId,empName,adjName:adjName||adjType,adjCode,regCol,
        adjAmt,remBal,divPeriod,applyPeriod,
        appliesToCutoff,expectedAmt,skipReason,
        // register amount filled below
        regAmt:'',variance:'',status:''
      });
    }
  }

  if(!results.length)return results;

  // ── 2. Build register lookup: empId|regCol → amount ──
  const regMap=new Map();
  const buildRegMap=(wb)=>{
    if(!wb)return;
    for(const sn of wb.SheetNames){
      if(skipTab(sn))continue;
      const ws=wb.Sheets[sn];if(!ws||!ws['!ref'])continue;
      const hr=findHdr(ws,ID_KEYS);if(hr<0)continue;
      const{headers,rows}=sheetRows(ws,hr);
      const ic=findIdCol(headers);if(!ic)continue;
      rows.forEach(row=>{
        const id=n2(row[ic]);if(!id||id.length<2)return;
        headers.forEach(h=>{
          if(!h)return;
          const val=toNum(row[h]);
          if(val===null)return;
          const key=id+'|'+h;
          // Store max value if multiple rows (accumulate)
          regMap.set(key,(regMap.get(key)||0)+val);
        });
      });
    }
  };
  buildRegMap(currRegWB);

  // ── 3. Match register amounts and determine status ──
  for(const r of results){
    if(r.skipReason){
      r.status=r.skipReason;
      continue;
    }

    // Try exact column match first, then fuzzy
    let regAmt=regMap.get(r.empId+'|'+r.regCol)||'';
    if(regAmt===''){
      // fuzzy: find any register column that contains the base loan name
      const baseNorm=normName(r.regCol.replace(/\(LESS\)/i,'').trim());
      for(const [k,v] of regMap){
        const [kid,kcol]=k.split('|');
        if(kid===r.empId&&normName(kcol.replace(/\(LESS\)/i,'').trim()).includes(baseNorm)){
          regAmt=v;break;
        }
      }
    }

    r.regAmt=regAmt!==''?parseFloat(regAmt.toFixed?regAmt.toFixed(2):regAmt):'';

    if(r.expectedAmt===null){
      r.status='AMOUNT NOT SET IN SUMMARY';
    } else if(r.regAmt===''){
      r.status='MISSING IN REGISTER';
    } else {
      r.variance=parseFloat((r.regAmt-r.expectedAmt).toFixed(2));
      r.status=r.variance===0?'MATCHED':'AMOUNT MISMATCH';
    }
  }

  // Sort: issues first, then matched, then skipped
  const sOrder={'MISSING IN REGISTER':0,'AMOUNT MISMATCH':1,'AMOUNT NOT SET IN SUMMARY':2,'MATCHED':3};
  results.sort((a,b)=>{
    const sa=sOrder[a.status]!==undefined?sOrder[a.status]:4;
    const sb=sOrder[b.status]!==undefined?sOrder[b.status]:4;
    if(sa!==sb)return sa-sb;
    return String(a.empId).localeCompare(String(b.empId),undefined,{numeric:true});
  });

  return results;
}

// ─── LOAN SECTION RENDERER ───────────────────────────────────
function renderLoanSection(rows,currRegWB,prevRegWB){
  const fmt=v=>(v===''||v===null||v===undefined)?'—':
    (typeof v==='number'?v.toLocaleString('en-PH',{minimumFractionDigits:2,maximumFractionDigits:2}):v);
  const fmtVar=v=>{
    if(v===''||v===null||v===undefined)return'—';
    const n=parseFloat(v);
    if(isNaN(n))return v;
    const s=Math.abs(n).toLocaleString('en-PH',{minimumFractionDigits:2,maximumFractionDigits:2});
    return n>0?`<span style="color:#dc2626;">+${s}</span>`:n<0?`<span style="color:#d97706;">${n<0?'-':''}${s}</span>`:'<span style="color:#16a34a;">0.00</span>';
  };

  const loanBadge=(s)=>{
    if(s==='MATCHED')return'<span class="badge" style="background:#f0fdf4;color:#16a34a;">&#10003; Matched</span>';
    if(s==='MISSING IN REGISTER')return'<span class="badge" style="background:#fef2f2;color:#dc2626;">&#10007; Missing in register</span>';
    if(s==='AMOUNT MISMATCH')return'<span class="badge" style="background:#fffbeb;color:#d97706;">&#9888; Amount mismatch</span>';
    if(s==='AMOUNT NOT SET IN SUMMARY')return'<span class="badge" style="background:#fffbeb;color:#d97706;">&#9888; Amount not set</span>';
    if(s.startsWith('COMPLETED'))return'<span class="badge" style="background:#f0fdf4;color:#16a34a;">&#10003; Completed</span>';
    if(s.startsWith('NOT APPLICABLE'))return'<span class="badge" style="background:#f3f4f6;color:#6b7280;">&#8212; '+s.split('—')[1].trim()+'</span>';
    return`<span class="badge" style="background:#f3f4f6;color:#6b7280;">${s}</span>`;
  };

  const activeRows=rows.filter(r=>r.appliesToCutoff);
  const skipRows=rows.filter(r=>!r.appliesToCutoff);
  const issueRows=activeRows.filter(r=>r.status!=='MATCHED');
  const okRows=activeRows.filter(r=>r.status==='MATCHED');

  document.getElementById('loan-total').textContent=activeRows.length;
  document.getElementById('loan-matched').textContent=okRows.length;
  document.getElementById('loan-issues').textContent=issueRows.length;
  document.getElementById('loan-skipped').textContent=skipRows.length;
  document.getElementById('cnt-loan-issues').textContent=issueRows.length;
  document.getElementById('cnt-loan-ok').textContent=okRows.length;
  document.getElementById('cnt-loan-skip').textContent=skipRows.length;

  const activeRowHtml=r=>`<tr>
    <td style="font-size:11px;color:#6b7280;">${r.empId}</td>
    <td style="font-weight:600;font-size:12px;">${r.empName||'—'}</td>
    <td><span class="badge" style="background:#f0f9ff;color:#0369a1;">${r.adjName}</span></td>
    <td style="font-size:11px;color:#6b7280;">${r.divPeriod==='yes'?'Both cutoffs':`Cutoff ${r.applyPeriod||'—'}`}</td>
    <td style="font-size:12px;">${fmt(r.expectedAmt)}</td>
    <td style="font-size:12px;">${fmt(r.regAmt)}</td>
    <td style="font-size:12px;">${fmtVar(r.variance)}</td>
    <td>${loanBadge(r.status)}</td></tr>`;

  const skipRowHtml=r=>`<tr>
    <td style="font-size:11px;color:#6b7280;">${r.empId}</td>
    <td style="font-weight:600;font-size:12px;">${r.empName||'—'}</td>
    <td><span class="badge" style="background:#f3f4f6;color:#6b7280;">${r.adjName}</span></td>
    <td style="font-size:11px;color:#6b7280;">${r.divPeriod==='yes'?'Both cutoffs':`Cutoff ${r.applyPeriod||'—'}`}</td>
    <td style="font-size:12px;">${r.remBal===null?'—':r.remBal===0?'<span style="color:#16a34a;">0.00</span>':fmt(r.remBal)}</td>
    <td>${loanBadge(r.status)}</td></tr>`;

  document.querySelector('#tbl-loan-issues tbody').innerHTML=issueRows.length
    ?issueRows.map(activeRowHtml).join('')
    :`<tr><td colspan="8" style="text-align:center;color:#9ca3af;padding:12px;">&#10003; No loan issues</td></tr>`;
  document.querySelector('#tbl-loan-ok tbody').innerHTML=okRows.length
    ?okRows.map(activeRowHtml).join('')
    :`<tr><td colspan="8" style="text-align:center;color:#9ca3af;padding:12px;">No matched loans</td></tr>`;
  document.querySelector('#tbl-loan-skip tbody').innerHTML=skipRows.length
    ?skipRows.map(skipRowHtml).join('')
    :`<tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:12px;">No completed or skipped loans</td></tr>`;

  document.getElementById('loanSection').style.display='block';
}

