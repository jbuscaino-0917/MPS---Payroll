      // Normalize numeric ID fields — strip decimals, pad leading zeros to match lengths
      const isNumId=normL(mfHdr).includes('tin')||normL(mfHdr).includes('sss')||
                    normL(mfHdr).includes('philhealth')||normL(mfHdr).includes('hdmf')||
                    normL(mfHdr).includes('bank account')||normL(iHdr).includes('bank account');
      if(isNumId){
        // Strip decimal part (e.g. 693825338.0 -> 693825338)
        iv=iv.replace(/\.0+$/,'').replace(/[^0-9]/g,'');
        mv=mv.replace(/\.0+$/,'').replace(/[^0-9]/g,'');
        // Pad to same length with leading zeros
        const maxLen=Math.max(iv.length,mv.length);
        if(iv.length>0)iv=iv.padStart(maxLen,'0');
        if(mv.length>0)mv=mv.padStart(maxLen,'0');
      }

      // Remarks: Excel formula if both exist, N/A if no masterfile entry
      const colOffset=fieldIdx*3;
      const getColLetter=n=>{
        let s='';
        n++;
        while(n>0){s=String.fromCharCode(64+(n%26||26))+s;n=Math.floor((n-1)/26);}
        return s;
      };
      const colA=getColLetter(colOffset);
      const colB=getColLetter(colOffset+1);
      const formula=mfRow?{f:`${colA}${excelRowNum}=${colB}${excelRowNum}`}:'N/A';

      dataRow.push(mv,iv,formula);
    });

    nhCmpAoa.push(dataRow);
  });

  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(nhCmpAoa.length>3?nhCmpAoa:[['No data']]),'NH vs Masterfile');




  const fn=`PaySprout_${clientName.replace(/\s/g,'_')}_${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}.xlsx`;
  // ── ADJUSTMENT VALIDATION ──
  if(exportData.adjWB&&exportData.instrWB){
    const adjValRows=buildAdjValidation(exportData.instrWB,exportData.masterWB,exportData.adjWB,exportData.currRegWB);
    if(adjValRows.length>0){
