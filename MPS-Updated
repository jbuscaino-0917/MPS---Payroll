      iRes.rows.forEach(ir=>{const id=norm(ir[iResIc]);if(!id)return;if(hMap.has(id))resOk.push({id,row:ir});else resMiss.push({id,row:ir});});
    } else {
      iRes.rows.forEach(ir=>{const id=norm(ir[iResIc]);if(!id)return;resMiss.push({id,row:ir});});
