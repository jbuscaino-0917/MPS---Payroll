  document.getElementById('hc-prev').textContent=pIDs.size;document.getElementById('hc-curr').textContent=cIDs.size;document.getElementById('hc-added').textContent=added.length;document.getElementById('hc-removed').textContent=removed.length;
  hcRows=[...added.map(id=>({id,name:(cMap.get(id)&&cMap.get(id).name)||'\u2014',empStatus:(cMap.get(id)&&cMap.get(id).empStatus)||'',prev:'\u2014',curr:'v In current',status:'added'})),...removed.map(id=>({id,name:(pMap.get(id)&&pMap.get(id).name)||'\u2014',empStatus:(pMap.get(id)&&pMap.get(id).empStatus)||'',prev:'v In previous',curr:'\u2014',status:'removed'})),...retained.map(id=>({id,name:(cMap.get(id)&&cMap.get(id).name)||'\u2014',empStatus:(cMap.get(id)&&cMap.get(id).empStatus)||'',prev:'v In previous',curr:'v In current',status:'retained'}))];
  renderHC('all');
  if(vFiles.adj){addLog('#0891b2','#ecfeff',`One-time adjustment — <strong>${vFiles.adj.name}</strong> loaded`);}
  if(vFiles.attend){addLog('#059669','#ecfdf5',`Current attendance — <strong>${vFiles.attend.name}</strong> loaded`);}
  if(vFiles.adjsum){addLog('#7c3aed','#f5f3ff',`Adjustment summary report — <strong>${vFiles.adjsum.name}</strong> loaded`);}
  if(vFiles.loansum){addLog('#0369a1','#f0f9ff',`Loan validation summary — <strong>${vFiles.loansum.name}</strong> loaded`);}
  addLog('#16a34a','#f0fdf4',`Headcount — Previous: <strong>${pIDs.size}</strong>, Current: <strong>${cIDs.size}</strong>, Added: <strong style="color:#16a34a;">${added.length}</strong>, Removed: <strong style="color:#dc2626;">${removed.length}</strong>`);

  // ── Section 4: Attendance Validation (Late/Undertime & Absent) ──
