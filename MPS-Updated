  // Layout: Row 3 = header triplets [MF col, Instr col, Remarks], Row 4+ = data with Excel formulas

  // Date normalizer — ensure MM/DD/YYYY string format
  const normDate=v=>{
    if(!v)return '';
    const s=String(v).trim();
    // Already MM/DD/YYYY
    if(/^[0-9]{1,2}\/[0-9]{1,2}\/[0-9]{4}$/.test(s))return s;
    // Excel date serial
    const n=parseFloat(s);
    if(!isNaN(n)&&n>40000&&n<60000){
      const d=new Date(Math.round((n-25569)*86400*1000));
      const mo=String(d.getUTCMonth()+1).padStart(2,'0');
      const dy=String(d.getUTCDate()).padStart(2,'0');
      const yr=d.getUTCFullYear();
      return mo+'/'+dy+'/'+yr;
    }
    // Date object or ISO string
    const dt=new Date(s);
    if(!isNaN(dt.getTime())){
      const mo=String(dt.getUTCMonth()+1).padStart(2,'0');
      const dy=String(dt.getUTCDate()).padStart(2,'0');
      return mo+'/'+dy+'/'+dt.getUTCFullYear();
    }
    return s;
  };

  // Helper: fuzzy find a value from a row-object by header label
  const getVal=(rowObj,colLabel)=>{
    if(!rowObj||!colLabel)return '';
    // Try exact match first
    if(rowObj[colLabel]!==undefined)return norm(rowObj[colLabel]||'');
    const ll=normL(colLabel).replace(/[^a-z0-9]/g,'');
    const key=Object.keys(rowObj).find(k=>{
      const kl=normL(k).replace(/[^a-z0-9]/g,'');
      return kl===ll||(ll.length>3&&kl.includes(ll))||(kl.length>3&&ll.includes(kl));
    });
    return key?norm(rowObj[key]||''):'';
  };

  // Column mapping: [MF col header, Instr col header]
  const NH_MAP2=[
    ['Employee ID*',                  'Employee No.'],
    ['Last Name*',                    'Last Name'],
    ['First Name*',                   'First Name'],
    ['Middle Name',                   'Middle Name'],
