  // Row 4: header triplets [MF col, Instr col, Remarks]
  const hdrRow=[];
  NH_MAP2.forEach(([mfHdr,iHdr])=>{hdrRow.push(mfHdr,iHdr,'Remarks');});
  nhCmpAoa.push(hdrRow);

  // Section labels to skip (these appear as rows in the instructions but are not employees)
  const skipLabels=['change in personal','salary increase','merit increase','change in status',
    'for approval','correction','regulariz','promotion','transfer','rate change','adjustment'];
  const isLabelId=v=>{const l=normL(v);return skipLabels.some(k=>l.includes(k));};

  // Data rows — one per new hire from the New Hire List
  nhIds.forEach(rowId=>{
