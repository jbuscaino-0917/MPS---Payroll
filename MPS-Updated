    :`<tr><td colspan="${resSpan}" style="text-align:center;color:#9ca3af;padding:12px;">No matched resigned employees</td></tr>`;
  document.querySelector('#tbl-res-missing tbody').innerHTML=resMiss.length
    ?resMiss.map(r=>resRowHtml(r,'<span class="badge" style="background:#fef2f2;color:#dc2626;">&#10007; Not in HOLD tab</span>')).join('')
    :`<tr><td colspan="${resSpan}" style="text-align:center;color:#9ca3af;padding:12px;">&#10003; All resigned employees in HOLD tab</td></tr>`;
  addLog('#16a34a','#f0fdf4',`Resigned validation — <strong>${resOk.length} correctly in HOLD</strong>, <strong style="color:#dc2626;">${resMiss.length} missing</strong>`);

  const pMap=allIDs(pWB),cMap=allIDs(cWB);
  const pIDs=new Set(pMap.keys()),cIDs=new Set(cMap.keys());
  const added=[...cIDs].filter(id=>!pIDs.has(id));
