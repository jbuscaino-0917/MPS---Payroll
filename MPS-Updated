          if(mvl.includes('table1')||mvl==='ottable1'||mv==='OT Table 1'){
            mv='OT Table 1'; // keep so it shows FALSE — mismatch
          } else {
            mv='No OT'; // any non-OT-Table-1 value is acceptable
          }
        }
      }
      // Normalize OT Computation Table: Yes -> OT Table 1, No -> No OT
      if(normL(mfHdr).includes('ot computation')||normL(iHdr).includes('with ot')||normL(iHdr).includes('yes or no')){
        const normalizeOT=v=>{
          const vl=normL(v).replace(/[^a-z0-9]/g,'');
