const zCfg={instr:{z:'z-instr',t:'z-instr-t',s:'z-instr-s',cls:'zone up-instr'},master:{z:'z-master',t:'z-master-t',s:'z-master-s',cls:'zone up-master'},prev:{z:'z-prev',t:'z-prev-t',s:'z-prev-s',cls:'zone up-prev'},curr:{z:'z-curr',t:'z-curr-t',s:'z-curr-s',cls:'zone up-curr'},adj:{z:'z-adj',t:'z-adj-t',s:'z-adj-s',cls:'zone up-adj'},attend:{z:'z-attend',t:'z-attend-t',s:'z-attend-s',cls:'zone up-attend'},adjsum:{z:'z-adjsum',t:'z-adjsum-t',s:'z-adjsum-s',cls:'zone up-adjsum'},loansum:{z:'z-loansum',t:'z-loansum-t',s:'z-loansum-s',cls:'zone up-loansum'}};

function validateFile(f){
  const ext='.'+f.name.split('.').pop().toLowerCase();
  if(!ALLOWED_EXTS.includes(ext))return`Unsupported file type "${ext}". Accepted formats: .xlsx, .xls, .xlsm, .csv`;
  if(f.size>MAX_FILE_SIZE)return`File "${f.name}" is too large (${(f.size/1024/1024).toFixed(1)} MB). Maximum size is 50 MB.`;
  if(f.size===0)return`File "${f.name}" appears to be empty.`;
  return null;
}

// Parse a CSV string into a SheetJS workbook object
function csvToWorkbook(text){
  const ws=XLSX.utils.aoa_to_sheet(text.split(/\r?\n/).map(r=>{
    // Handle quoted fields with commas inside
    const cells=[];let cur='';let inQ=false;
    for(let i=0;i<r.length;i++){
      const ch=r[i];
      if(ch==='"'){if(inQ&&r[i+1]==='"'){cur+='"';i++;}else inQ=!inQ;}
      else if(ch===','&&!inQ){cells.push(cur);cur='';}
      else cur+=ch;
    }
    cells.push(cur);
    return cells;
  }));
  const wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,ws,'Sheet1');
  return wb;
}

function loadVFile(f,k){
  const err=validateFile(f);
  if(err){
    const cfg=zCfg[k];
    const se1=cfg&&document.getElementById(cfg.s);if(se1){se1.textContent='! '+err;se1.style.color='#dc2626';}
    return;
  }
  const cfg=zCfg[k];
  const ext='.'+f.name.split('.').pop().toLowerCase();
  if(cfg&&document.getElementById(cfg.s)){document.getElementById(cfg.s).textContent='Reading file...';document.getElementById(cfg.s).style.color='#6b7280';}

  const onSuccess=(wb)=>{
    vFiles[k]={wb,name:f.name};
    if(cfg){
      const ze=document.getElementById(cfg.z);if(ze)ze.className=cfg.cls;
      const te=document.getElementById(cfg.t);if(te)te.textContent=f.name;
      const se=document.getElementById(cfg.s);if(se){se.textContent=`${wb.SheetNames.length} tab(s) · Loaded`;se.style.color='#6b7280';}
    }
    renderFileSlots();
    const ready=vFiles.instr&&vFiles.master&&vFiles.prev&&vFiles.curr;
    document.getElementById('runBtn').disabled=!ready;
    document.getElementById('hint').textContent=ready?'All required files uploaded. Ready to run validation.':'Upload all 4 required files to enable validation.';
  };

  const onError=(msg)=>{
    const se2=cfg&&document.getElementById(cfg.s);if(se2){se2.textContent='! '+msg;se2.style.color='#dc2626';}
    vFiles[k]=null;
    document.getElementById('runBtn').disabled=true;
  };

  if(ext==='.csv'){
    // CSV: read as text, parse manually
    const tr=new FileReader();
    tr.onload=ev=>{
      try{
        const wb=csvToWorkbook(ev.target.result);
        onSuccess(wb);
      }catch(e){onError('Could not parse CSV file. Please check the file format.');}
    };
    tr.onerror=()=>onError('Failed to read the file. Please try again.');
    tr.readAsText(f);
  } else {
    // xlsx / xls / xlsm: read as ArrayBuffer
    const reader=new FileReader();
    reader.onload=ev=>{
      try{
        // Try standard read first; fall back to raw mode for non-standard files
        let wb;
        try{
          wb=XLSX.read(ev.target.result,{type:'array',cellDates:true});
        }catch(e1){
          // Some payroll exports are HTML-disguised-as-xlsx or other edge cases
          // Try without cellDates as a fallback
          wb=XLSX.read(ev.target.result,{type:'array'});
        }
        onSuccess(wb);
      }catch(e){
        onError('Could not parse this file. Try re-saving it as .xlsx in Excel, or export as .csv.');
      }
    };
    reader.onerror=()=>onError('Failed to read the file. Please try again.');
    reader.readAsArrayBuffer(f);
  }
}

// ─── CORE FUNCTIONS ────────────────────────────────────────
const norm=v=>String(v==null?'':v).trim();
const normL=v=>norm(v).toLowerCase();
const skipTab=name=>SKIP_TABS.some(s=>normL(name).replace(/\s/g,'').includes(s.replace(/\s/g,'')));
function findHdr(ws,keys,max=100){const range=XLSX.utils.decode_range(ws['!ref']||'A1:A1');for(let r=range.s.r;r<=Math.min(range.e.r,max);r++)for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r,c})];if(cell&&keys.some(k=>normL(cell.v)===k||normL(cell.v).includes(k)))return r;}return -1;}
function sheetRows(ws,hr){if(hr<0)return{headers:[],rows:[]};const range=XLSX.utils.decode_range(ws['!ref']||'A1:A1');const headers=[];for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r:hr,c})];headers.push(cell?norm(cell.v):'');}const rows=[];for(let r=hr+1;r<=range.e.r;r++){const row={};let has=false;for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r,c})];const val=cell?norm(cell.v):'';row[headers[c-range.s.c]]=val;if(val)has=true;}if(has)rows.push(row);}return{headers:headers.filter(h=>h),rows};}
function findIdCol(h){return h.find(x=>ID_KEYS.includes(normL(x)))||h.find(x=>ID_KEYS.some(k=>normL(x).includes(k)));}
function findNameCol(h){return h.find(x=>NAME_KEYS.some(k=>normL(x)===k||normL(x).includes(k)));}
function extractTab(wb,tabKeys){const n=wb.SheetNames.find(x=>tabKeys.some(k=>normL(x).replace(/\s/g,'')===k.replace(/\s/g,'')||normL(x).includes(k)));if(!n)return{rows:[],headers:[],tabName:null};const ws=wb.Sheets[n];if(!ws||!ws['!ref'])return{rows:[],headers:[],tabName:n};const hr=findHdr(ws,ID_KEYS);const{headers,rows}=sheetRows(ws,hr);return{rows,headers,tabName:n};}
function extractAllSections(wb){
  const loose=s=>s.toLowerCase().replace(/[^a-z0-9]/g,'');
  const nhKL=NH_SEC.map(loose);
  const resKL=RES_SEC.map(loose);
  // Section headers that signal we've left the NH/Res section — reset mode to null
  const OTHER_SEC=[
    'change in status','changein','salary increase','salaryincrease','merit increase','meritincrease',
    'rate change','ratechange','promotion','transfer','regularization','regularized',
    'adjustment','additional pay','additionalpay','special pay','specialpay',
    'allowance change','allowancechange','correction','for approval','forapproval',
    'one time','onetime','bonus','13th month','14th month','leave','loan','deduction',
    'retroactive','retro','lump sum','lumpsum',
    'new hires allowance','newhiresallowance','allowance outside','hires allowance',
    'outside basic','outsidebasic','new hire allowance','newhireallowance',
    'change in personal','changeinpersonal','personal info','personalinfo',
    'salary increase','salaryincrease','merit increase','meritincrease',
    'change in info','changeininfo','information update'
  ];
  const isSec=(v,keys)=>{const l=loose(v);return l.length>=4&&keys.some(k=>l.includes(k)||k.includes(l));};
  const isOtherSec=(v)=>{const l=loose(v);return l.length>=4&&OTHER_SEC.some(k=>l.includes(k)||k.includes(l));};
  const isSkip=v=>{const l=v.toLowerCase();return l.startsWith('hr note')||l.includes('hr notes')||l.startsWith('note')||l.startsWith('memo');};
  const sniffMode=raw=>{
    const L=raw.map(v=>loose(norm(v)));
    if(L.some(v=>v.includes('effectiv')||v.includes('lastday')||v.includes('lastwork')))return'res';
    if(L.some(v=>v.includes('startdate')||v.includes('hiredate')||v.includes('basicpay')))return'nh';
    return null;
  };
  let nhRows=[],nhHeaders=[],nhSheet=null;
  let resRows=[],resHeaders=[],resSheet=null;
  for(const sn of wb.SheetNames){
    const ws=wb.Sheets[sn];if(!ws||!ws['!ref'])continue;
    const range=XLSX.utils.decode_range(ws['!ref']);
    let mode=null,hdr=[],idCol=null;
    for(let r=range.s.r;r<=range.e.r;r++){
      const raw=[];
      for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r,c})];raw.push(cell?norm(cell.v):'');}
      const nonEmpty=raw.filter(v=>v);
      const first=nonEmpty[0]||'';
      if(!first)continue;
      const sparse=nonEmpty.length<=3;
      const pool=sparse?nonEmpty:[first];
      const hasNH=pool.some(v=>isSec(v,nhKL));
      const hasRES=pool.some(v=>isSec(v,resKL));
      // Check ALL non-empty cells for other section headers (not just sparse rows)
      // This catches labels like "Salary Increase :" even when they have NOTE/text beside them
      const hasOther=!hasNH&&!hasRES&&nonEmpty.some(v=>isOtherSec(v));
      if(hasNH&&!hasRES){mode='nh';hdr=[];idCol=null;continue;}
      if(hasRES){mode='res';hdr=[];idCol=null;continue;}
      if(hasOther){mode=null;hdr=[];idCol=null;continue;}
      if(isSkip(first))continue;
      if(!idCol){
        const potId=findIdCol(raw);
        if(potId){
          hdr=raw;idCol=potId;
          const sniffed=sniffMode(raw);
          if(sniffed)mode=sniffed;
          else if(!mode){hdr=[];idCol=null;}
        }
        continue;
      }
      if(!mode)continue;
      if(ID_KEYS.some(k=>raw.some(v=>loose(norm(v))===loose(k)))){
        const sniffed=sniffMode(raw);
        const potId=findIdCol(raw);
        if(sniffed&&potId){mode=sniffed;hdr=raw;idCol=potId;}
        else{mode=null;hdr=[];idCol=null;}
        continue;
      }
      const row={};raw.forEach((v,i)=>{if(hdr[i])row[hdr[i]]=v;});
      const id=norm(row[idCol]);
      if(!id||id.length<2)continue;
      if(ID_KEYS.some(k=>normL(id)===k||normL(id).includes(k)))continue;
      if(isSec(id,nhKL)||isSec(id,resKL))continue;
      if(mode==='nh'){if(!nhSheet){nhHeaders=hdr.filter(h=>h);nhSheet=sn;}nhRows.push(row);}
      else if(mode==='res'){if(!resSheet){resHeaders=hdr.filter(h=>h);resSheet=sn;}resRows.push(row);}
    }
  }
  if(!nhRows.length){const f=extractSectionFallback(wb,NH_SEC);nhRows=f.rows;nhHeaders=f.headers;nhSheet=f.sheetName;}
  if(!resRows.length){const f=extractSectionFallback(wb,RES_SEC);resRows=f.rows;resHeaders=f.headers;resSheet=f.sheetName;}
  if(!resRows.length){
    outer:for(const sn of wb.SheetNames){
      const ws=wb.Sheets[sn];if(!ws||!ws['!ref'])continue;
      const range=XLSX.utils.decode_range(ws['!ref']);
      for(let ri=range.s.r;ri<=Math.min(range.e.r,300);ri++){
        const raw=[];
        for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r:ri,c})];raw.push(cell?norm(cell.v):'');}
        const hasEffectiv=raw.some(v=>{const l=v.toLowerCase().replace(/\s/g,'');return l.includes('effectiv')||l.includes('lastday')||l.includes('lastwork');});
        const potId=findIdCol(raw);
        if(potId&&hasEffectiv){
          const{headers,rows}=sheetRows(ws,ri);
          const ic=findIdCol(headers);
          if(ic){
            const vr=rows.filter(r=>norm(r[ic])&&!ID_KEYS.some(k=>normL(norm(r[ic]))===k));
            if(vr.length){resRows=vr;resHeaders=headers.filter(h=>h);resSheet=sn;break outer;}
          }
        }
      }
    }
  }
  return{
    nh:{rows:nhRows,headers:nhHeaders,sheetName:nhSheet},
    res:{rows:resRows,headers:resHeaders,sheetName:resSheet}
  };
}
function extractSectionFallback(wb,secKeys){
  const loose=s=>s.toLowerCase().replace(/[\s\/\-_:]/g,'');
  const secKeysLoose=secKeys.map(loose);
  for(const sn of wb.SheetNames){
    const ws=wb.Sheets[sn];if(!ws||!ws['!ref'])continue;
    if(secKeysLoose.some(k=>loose(sn).includes(k)||k.includes(loose(sn)))){
      const hr=findHdr(ws,ID_KEYS);
      if(hr>=0){const{headers,rows}=sheetRows(ws,hr);const ic=findIdCol(headers);
        if(ic&&rows.some(r=>norm(r[ic])))return{rows:rows.filter(r=>norm(r[ic])),headers,sheetName:sn};}
    }
  }
  for(const sn of wb.SheetNames){
    const ws=wb.Sheets[sn];if(!ws||!ws['!ref'])continue;
    const range=XLSX.utils.decode_range(ws['!ref']);
    for(let r=range.s.r;r<=Math.min(range.e.r,200);r++){
      for(let c=range.s.c;c<=range.e.c;c++){
        const cell=ws[XLSX.utils.encode_cell({r,c})];if(!cell||!cell.v)continue;
        const v=loose(norm(cell.v));
        if(secKeysLoose.some(k=>v.includes(k)||k.includes(v))&&v.length>=4){
          const hr2=findHdrFrom(ws,r+1,ID_KEYS,30);
          if(hr2>=0){const{headers,rows}=sheetRows(ws,hr2);const ic=findIdCol(headers);
            if(ic){const vr=rows.filter(r2=>{const id=norm(r2[ic]);return id&&id.length>=2&&!secKeysLoose.some(k=>loose(id).includes(k))&&!loose(id).includes('hrnote');});
              if(vr.length>0)return{rows:vr,headers,sheetName:sn};}}
        }
      }
    }
  }
  for(const sn of wb.SheetNames){
    const ws=wb.Sheets[sn];if(!ws||!ws['!ref'])continue;
    const hr=findHdr(ws,ID_KEYS);if(hr<0)continue;
    const{headers,rows}=sheetRows(ws,hr);const ic=findIdCol(headers);
    if(ic&&rows.filter(r=>norm(r[ic])).length>0)return{rows:rows.filter(r=>norm(r[ic])),headers,sheetName:sn};
  }
  return{rows:[],headers:[],sheetName:null};
}
function findHdrFrom(ws,start,keys,max=15){const range=XLSX.utils.decode_range(ws['!ref']||'A1:A1');for(let r=start;r<=Math.min(range.e.r,start+max);r++)for(let c=range.s.c;c<=range.e.c;c++){const cell=ws[XLSX.utils.encode_cell({r,c})];if(cell&&keys.some(k=>normL(cell.v)===k||normL(cell.v).includes(k)))return r;}return -1;}
function allIDs(wb){const map=new Map();wb.SheetNames.forEach(n=>{if(skipTab(n))return;const ws=wb.Sheets[n];if(!ws||!ws['!ref'])return;const hr=findHdr(ws,ID_KEYS);if(hr<0)return;const{headers,rows}=sheetRows(ws,hr);const ic=findIdCol(headers),nc=findNameCol(headers);if(!ic)return;const sc=headers.find(h=>normL(h).includes('employment status')||normL(h).includes('emp status')||normL(h).includes('status'));rows.forEach(r=>{const id=norm(r[ic]);if(!id)return;if(!map.has(id))map.set(id,{id,name:nc?norm(r[nc]):'\u2014',empStatus:sc?norm(r[sc]):'',tabs:[]});const e=map.get(id);if(!e.tabs.includes(n))e.tabs.push(n);if(sc&&!e.empStatus&&norm(r[sc]))e.empStatus=norm(r[sc]);});});return map;}
function addLog(col,bg,msg){const d=document.createElement('div');d.className='log-item';d.innerHTML=`<div class="log-icon" style="background:${bg};"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="${col}" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><span style="color:#374151;font-size:12px;">${msg}</span>`;document.getElementById('logArea').appendChild(d);}
function addWarn(msg){const d=document.createElement('div');d.className='log-item';d.innerHTML=`<div class="log-icon" style="background:#fffbeb;"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="3"><polygon points="12 2 22 21 2 21"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div><span style="color:#374151;font-size:12px;">${msg}</span>`;document.getElementById('logArea').appendChild(d);}

