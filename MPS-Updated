  if(iNH.rows.length)addLog('#16a34a','#f0fdf4',`Instructions — <strong>${iNH.rows.length} new hire(s)</strong> detected across all sheets`);
  else addWarn('Instructions — New Hire section not found in any sheet.');
  if(mNH.tabName)addLog('#16a34a','#f0fdf4',`Masterfile — NH tab: "<strong>${mNH.tabName}</strong>" · ${mNH.rows.length} records`);
