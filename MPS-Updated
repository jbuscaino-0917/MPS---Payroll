  const resTotal=iRes.rows.filter(r=>iResIc&&norm(r[iResIc])).length;
  document.getElementById('res-total').textContent=resTotal;document.getElementById('res-matched').textContent=resOk.length;document.getElementById('res-issues').textContent=resMiss.length;
