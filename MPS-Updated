<!DOCTYPE html>
<html>
<head>
<style>
/* ── Sprout Solutions Brand Tokens ── */
:root {
  --sp-green: #32CE13;
  --sp-deep: #092903;
  --sp-deep2: #0f3d07;
  --sp-lime: #D2F612;
  --sp-ubas: #8139EE;
  --sp-carrot: #FF7F00;
  --sp-blue: #1679FA;
  --sp-sidebar-w: 220px;
  --sp-topbar-h: 52px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 14px; color: #111; background: #f4f6f3; min-height: 100vh; }

/* ── SCREEN / LAYOUT ── */
.screen { display: none; }
.screen.active { display: flex; min-height: 100vh; }
#sc-login.active { display: block; background: var(--sp-deep); }

/* Sidebar shell used by dashboard, validator, history */
.app-layout { display: flex; min-height: 100vh; width: 100%; }

/* ── SIDEBAR ── */
.sidebar {
  width: var(--sp-sidebar-w); flex-shrink: 0; background: var(--sp-deep);
  display: flex; flex-direction: column; position: fixed; top: 0; left: 0;
  height: 100vh; z-index: 20; overflow: hidden;
}
.sb-logo { padding: 20px 18px 16px; border-bottom: 0.5px solid rgba(255,255,255,0.07); }
.sb-logo-row { display: flex; align-items: center; gap: 9px; }
.sb-logo-mark { width: 28px; height: 28px; background: var(--sp-green); border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.sb-logo-text { font-size: 15px; font-weight: 600; color: #fff; letter-spacing: -0.3px; }
.sb-logo-sub { font-size: 10px; color: rgba(255,255,255,0.35); margin-top: 2px; letter-spacing: 0.04em; }
.sb-section { padding: 10px 10px 4px; font-size: 9px; font-weight: 600; color: rgba(255,255,255,0.28); letter-spacing: 0.1em; text-transform: uppercase; }
.sb-nav { flex: 1; padding: 8px 10px; overflow-y: auto; }
.sb-item {
  display: flex; align-items: center; gap: 10px; padding: 9px 10px;
  border-radius: 8px; cursor: pointer; font-size: 12px; font-weight: 500;
  color: rgba(255,255,255,0.5); margin-bottom: 2px; transition: all 0.12s;
  border: none; background: none; width: 100%; text-align: left;
}
.sb-item:hover { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.85); }
.sb-item.active { background: rgba(50,206,19,0.15); color: #fff; }
.sb-item.active .sb-dot { background: var(--sp-green); }
.sb-dot { width: 6px; height: 6px; border-radius: 50%; background: transparent; flex-shrink: 0; }
.sb-badge { margin-left: auto; font-size: 10px; background: var(--sp-green); color: var(--sp-deep); font-weight: 700; padding: 1px 6px; border-radius: 10px; }
.sb-footer { padding: 12px 10px; border-top: 0.5px solid rgba(255,255,255,0.07); }
.sb-user { display: flex; align-items: center; gap: 9px; padding: 8px 10px; border-radius: 8px; }
.sb-user-avatar { width: 30px; height: 30px; border-radius: 50%; background: rgba(50,206,19,0.2); border: 1.5px solid rgba(50,206,19,0.4); display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; color: var(--sp-green); flex-shrink: 0; }
.sb-user-name { font-size: 12px; font-weight: 600; color: #fff; }
.sb-user-role { font-size: 10px; color: rgba(255,255,255,0.35); }
.sb-signout { width: 100%; margin-top: 6px; font-size: 11px; padding: 7px; border: 0.5px solid rgba(255,255,255,0.12); border-radius: 7px; background: none; color: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.12s; }
.sb-signout:hover { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.7); }

/* ── MAIN CONTENT AREA ── */
.main-area { margin-left: var(--sp-sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
.topbar {
  height: var(--sp-topbar-h); background: #fff; border-bottom: 0.5px solid #e5e7eb;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 1.5rem; position: sticky; top: 0; z-index: 10;
}
.topbar-left { display: flex; align-items: center; gap: 10px; }
.topbar-title { font-size: 14px; font-weight: 600; color: #111; }
.topbar-meta { font-size: 11px; color: #6b7280; }
.topbar-sep { width: 0.5px; height: 18px; background: #e5e7eb; }
.topbar-crumb { font-size: 12px; color: #6b7280; display: flex; align-items: center; gap: 4px; }
.topbar-right { display: flex; align-items: center; gap: 10px; }
.cycle-pill { font-size: 11px; background: #f0fdf4; border: 0.5px solid #bbf7d0; color: #166534; padding: 3px 10px; border-radius: 20px; font-weight: 500; }

.page { max-width: 1020px; margin: 0 auto; padding: 1.5rem; width: 100%; }

/* ── CARDS / METRICS ── */
.card { background: #fff; border: 0.5px solid #e5e7eb; border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
.sl { font-size: 10px; font-weight: 700; color: #6b7280; letter-spacing: 0.09em; text-transform: uppercase; margin-bottom: 8px; }
.metric { background: #f4f6f3; border-radius: 8px; padding: 10px 14px; }
.ml { font-size: 11px; color: #6b7280; margin-bottom: 3px; }
.mv { font-size: 21px; font-weight: 700; }

/* ── TABLES ── */
.tbl { width: 100%; border-collapse: collapse; font-size: 12px; table-layout: fixed; }
.tbl th { font-size: 10px; font-weight: 700; color: #6b7280; text-align: left; padding: 8px 12px; border-bottom: 0.5px solid #e5e7eb; background: #f8faf7; white-space: nowrap; letter-spacing: 0.04em; text-transform: uppercase; }
.tbl td { padding: 9px 12px; border-bottom: 0.5px solid #f3f4f6; color: #111; vertical-align: middle; }
.tbl tr:last-child td { border-bottom: none; }
.tbl tr:hover td { background: #f8faf7; }

/* ── BADGES ── */
.badge { display: inline-block; font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 20px; white-space: nowrap; }
.avatar { width: 28px; height: 28px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; flex-shrink: 0; }

/* ── BUTTONS ── */
.iBtn { background: none; border: none; cursor: pointer; padding: 4px; border-radius: 6px; display: inline-flex; align-items: center; }
.iBtn:hover { background: #f0fdf4; }
.green-btn { background: var(--sp-green); color: #092903; border: none; border-radius: 8px; padding: 9px; font-size: 13px; font-weight: 700; cursor: pointer; width: 100%; transition: opacity 0.12s; }
.green-btn:hover { opacity: 0.9; }
.green-btn:disabled { opacity: 0.35; cursor: not-allowed; }
.run-btn { background: var(--sp-green); color: #092903; border: none; border-radius: 8px; padding: 8px 18px; font-size: 13px; font-weight: 700; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; transition: opacity 0.12s; }
.run-btn:hover { opacity: 0.9; }
.run-btn:disabled { opacity: 0.35; cursor: not-allowed; }
.exp-btn { background: #fff; color: #111; border: 0.5px solid #e5e7eb; border-radius: 8px; padding: 7px 14px; font-size: 13px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
.exp-btn:hover { background: #f8faf7; }
.exp-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.outline-btn { background: #fff; color: #111; border: 0.5px solid #e5e7eb; border-radius: 8px; padding: 6px 12px; font-size: 12px; cursor: pointer; display: inline-flex; align-items: center; gap: 5px; }
.outline-btn:hover { background: #f8faf7; }

/* ── TABS ── */
.tab { font-size: 12px; font-weight: 500; padding: 5px 14px; border-radius: 8px; border: none; cursor: pointer; background: none; color: #6b7280; }
.tab.active { background: #fff; color: #092903; border: 0.5px solid #e5e7eb; font-weight: 700; }

/* ── LOGIN ROLE CARDS ── */
.role-card { border: 0.5px solid #e5e7eb; border-radius: 12px; padding: 1rem; cursor: pointer; background: #f9fafb; text-align: center; transition: border-color 0.12s, background 0.12s; }
.role-card:hover { border-color: var(--sp-green); background: rgba(50,206,19,0.06); }
.role-card.selected { border: 2px solid var(--sp-green); background: rgba(50,206,19,0.08); }
.user-opt { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 8px; cursor: pointer; border: 0.5px solid #e5e7eb; background: #f9fafb; margin-bottom: 6px; transition: background 0.12s; }
.user-opt:hover { background: #f0fdf4; border-color: #bbf7d0; }
.user-opt.selected { border-color: var(--sp-green); background: rgba(50,206,19,0.08); }

/* ── MODALS ── */
.modal-bg { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; align-items: center; justify-content: center; }
.modal-bg.open { display: flex; }
.modal { background: #fff; border-radius: 16px; padding: 1.5rem; width: 90%; max-width: 500px; max-height: 90vh; overflow-y: auto; }

/* ── FILE UPLOAD ZONES ── */
.zone { border: 1.5px dashed #d1d5db; border-radius: 10px; padding: 1rem; text-align: center; cursor: pointer; background: #f8faf7; position: relative; transition: all 0.15s; }
.zone:hover { border-color: var(--sp-green); background: #f0fdf4; }
.zone input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
.zone.up-instr { border-color: #f59e0b; background: #fffbeb; border-style: solid; }
.zone.up-master { border-color: var(--sp-green); background: #f0fdf4; border-style: solid; }
.zone.up-prev { border-color: var(--sp-blue); background: #eff6ff; border-style: solid; }
.zone.up-curr { border-color: var(--sp-ubas); background: #f5f3ff; border-style: solid; }
.zone.up-adj { border-color: #0891b2; background: #ecfeff; border-style: solid; }
.zone.up-attend { border-color: #059669; background: #ecfdf5; border-style: solid; }
.zone.up-adjsum { border-color: var(--sp-ubas); background: #f5f3ff; border-style: solid; }
.zone.up-loansum { border-color: #0369a1; background: #f0f9ff; border-style: solid; }

/* ── FILTER BUTTONS ── */
.fb { font-size: 12px; padding: 4px 12px; border-radius: 20px; cursor: pointer; border: 0.5px solid #d1d5db; background: none; color: #6b7280; }
.fb.active { background: #f0fdf4; color: #166534; border-color: #86efac; font-weight: 600; }

/* ── SECTION BLOCKS ── */
.gh { display: flex; align-items: center; gap: 8px; padding: 9px 12px; flex-wrap: wrap; }
.sec-block { border: 0.5px solid #e5e7eb; border-radius: 12px; overflow: hidden; margin-bottom: 1.5rem; }
.log-item { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; margin-bottom: 5px; }
.log-icon { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.divider { height: 0.5px; background: #e5e7eb; margin: 1.25rem 0; }
.hist-run { background: #fff; border: 0.5px solid #e5e7eb; border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
.hist-run:hover { border-color: #bbf7d0; }
.timeline-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
.stat-pill { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; margin: 2px; }

/* ── HERO BANNER ── */
.dash-hero { background: var(--sp-deep); border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; position: relative; overflow: hidden; }
.dash-hero::before { content: ''; position: absolute; top: -30px; right: -30px; width: 180px; height: 180px; border-radius: 50%; background: rgba(50,206,19,0.06); pointer-events: none; }
.dash-hero::after { content: ''; position: absolute; bottom: -40px; right: 60px; width: 120px; height: 120px; border-radius: 50%; background: rgba(210,246,18,0.04); pointer-events: none; }

/* ── INPUTS ── */
input[type=text], select { height: 36px; border: 0.5px solid #d1d5db; border-radius: 8px; padding: 0 10px; font-size: 13px; background: #fff; color: #111; }
input[type=text]:focus, select:focus { outline: none; border-color: var(--sp-green); box-shadow: 0 0 0 3px rgba(50,206,19,0.1); }

@keyframes spin { from{transform:rotate(0deg);} to{transform:rotate(360deg);} }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="sc-login" class="screen active">
  <div style="min-height:100vh;display:flex;">
    <!-- Left panel -->
    <div style="width:420px;flex-shrink:0;background:var(--sp-deep);display:flex;flex-direction:column;justify-content:space-between;padding:2.5rem 2rem;">
      <div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:3rem;">
          <div style="width:32px;height:32px;background:var(--sp-green);border-radius:8px;display:flex;align-items:center;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#092903" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <span style="font-size:18px;font-weight:700;color:#fff;letter-spacing:-0.3px;">PaySprout</span>
        </div>
        <p style="font-size:26px;font-weight:700;color:#fff;line-height:1.3;margin-bottom:12px;">Payroll variance<br>made simple.</p>
        <p style="font-size:13px;color:rgba(255,255,255,0.45);line-height:1.6;">Validate new hires, resignations, headcount, adjustments, attendance, loans, and recurring deductions — all in one run.</p>
        <div style="margin-top:2rem;display:flex;flex-direction:column;gap:10px;">
          <div style="display:flex;align-items:center;gap:10px;"><div style="width:6px;height:6px;border-radius:50%;background:var(--sp-green);flex-shrink:0;"></div><span style="font-size:12px;color:rgba(255,255,255,0.5);">New hire & resignation validation</span></div>
          <div style="display:flex;align-items:center;gap:10px;"><div style="width:6px;height:6px;border-radius:50%;background:var(--sp-lime);flex-shrink:0;"></div><span style="font-size:12px;color:rgba(255,255,255,0.5);">Attendance & adjustment cross-check</span></div>
          <div style="display:flex;align-items:center;gap:10px;"><div style="width:6px;height:6px;border-radius:50%;background:var(--sp-blue);flex-shrink:0;"></div><span style="font-size:12px;color:rgba(255,255,255,0.5);">Recurring & loans verification</span></div>
          <div style="display:flex;align-items:center;gap:10px;"><div style="width:6px;height:6px;border-radius:50%;background:var(--sp-ubas);flex-shrink:0;"></div><span style="font-size:12px;color:rgba(255,255,255,0.5);">Team-based role access control</span></div>
        </div>
      </div>
      <p style="font-size:11px;color:rgba(255,255,255,0.2);">© 2026 Sprout Solutions · Payroll Variance Tool</p>
    </div>
    <!-- Right panel -->
    <div style="flex:1;background:#f4f6f3;display:flex;align-items:center;justify-content:center;padding:2rem;">
      <div style="width:100%;max-width:400px;">
        <p style="font-size:22px;font-weight:700;color:#092903;margin-bottom:4px;">Sign in</p>
        <p style="font-size:13px;color:#6b7280;margin-bottom:1.5rem;">Select your role and user to continue</p>
        <div style="background:#fff;border:0.5px solid #e5e7eb;border-radius:14px;padding:1.25rem;">
          <p class="sl" style="margin-bottom:10px;color:#092903;">Select role</p>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:1.25rem;">
            <div class="role-card" id="rc-admin" onclick="selectRole('admin')">
              <div style="width:28px;height:28px;border-radius:8px;background:#f0fdf4;border:0.5px solid #bbf7d0;display:flex;align-items:center;justify-content:center;margin-bottom:6px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#166534" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <p style="font-size:12px;font-weight:700;color:#111;">Admin</p><p style="font-size:11px;color:#6b7280;">All clients</p>
            </div>
            <div class="role-card" id="rc-lead" onclick="selectRole('lead')">
              <div style="width:28px;height:28px;border-radius:8px;background:#fefce8;border:0.5px solid #fef08a;display:flex;align-items:center;justify-content:center;margin-bottom:6px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#854d0e" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></div>
              <p style="font-size:12px;font-weight:700;color:#111;">Lead</p><p style="font-size:11px;color:#6b7280;">Team only</p>
            </div>
            <div class="role-card" id="rc-member" onclick="selectRole('member')">
              <div style="width:28px;height:28px;border-radius:8px;background:#f5f3ff;border:0.5px solid #ddd6fe;display:flex;align-items:center;justify-content:center;margin-bottom:6px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6d28d9" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
              <p style="font-size:12px;font-weight:700;color:#111;">Member</p><p style="font-size:11px;color:#6b7280;">Own accounts</p>
            </div>
          </div>
          <div id="userPicker" style="display:none;margin-bottom:1rem;">
            <p class="sl" style="margin-bottom:8px;color:#092903;">Select user</p>
            <div id="userList"></div>
          </div>
          <button class="green-btn" id="loginBtn" disabled onclick="doLogin()">Sign in to PaySprout</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- DASHBOARD -->
<div id="sc-dash" class="screen">
  <div class="app-layout">
    <!-- Sidebar -->
    <div class="sidebar">
      <div class="sb-logo">
        <div class="sb-logo-row">
          <div class="sb-logo-mark"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#092903" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <div><div class="sb-logo-text">PaySprout</div><div class="sb-logo-sub">Sprout Solutions</div></div>
        </div>
      </div>
      <div class="sb-nav">
        <div class="sb-section">Main</div>
        <button class="sb-item active" onclick="goTo('sc-dash')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          Dashboard
          <div class="sb-dot"></div>
        </button>
        <button class="sb-item" onclick="openFreeValidator()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          Validator
        </button>
        <div class="sb-section" style="margin-top:8px;">Clients</div>
        <button class="sb-item" onclick="switchTab('active');goTo('sc-dash')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Active
        </button>
        <button class="sb-item" onclick="switchTab('completed');goTo('sc-dash')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          Completed
        </button>
      </div>
      <div class="sb-footer">
        <div class="sb-user">
          <div class="sb-user-avatar" id="sbAvatar1">SA</div>
          <div><div class="sb-user-name" id="sbName1">Admin</div><div class="sb-user-role" id="sbRole1">admin</div></div>
        </div>
        <button class="sb-signout" onclick="doLogout()">Sign out</button>
      </div>
    </div>
    <!-- Main area -->
    <div class="main-area">
      <div class="topbar">
        <div class="topbar-left">
          <span class="topbar-title">Dashboard</span>
          <div class="topbar-sep"></div>
          <span class="cycle-pill">April 2026 · Active</span>
        </div>
        <div class="topbar-right">
          <button onclick="openAddModal()" style="font-size:12px;padding:6px 14px;border:none;border-radius:8px;background:var(--sp-green);color:#092903;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:5px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Add client
          </button>
        </div>
      </div>
      <div class="page">
        <div class="dash-hero">
          <div>
            <p style="font-size:10px;color:rgba(255,255,255,0.5);font-weight:600;letter-spacing:0.09em;text-transform:uppercase;margin-bottom:4px;" id="greetTime">Good morning</p>
            <p style="font-size:20px;font-weight:700;color:#fff;margin-bottom:2px;" id="greetName">Welcome back!</p>
            <p style="font-size:12px;color:rgba(255,255,255,0.45);" id="greetDate"></p>
          </div>
          <div style="text-align:right;">
