function autoDetectAndLoad(file){
  const nl=s=>s.toLowerCase().replace(/[^a-z0-9]/g,'');
  const fn=nl(file.name);
  let slot=null;
  if(fn.includes('instruction')||fn.includes('payrollinstr'))slot='instr';
  else if(fn.includes('loansummary')||fn.includes('loanvalidation')||fn.includes('loansval'))slot='loansum';
  else if(fn.includes('adjustmentsummary')||fn.includes('adjsummary'))slot='adjsum';
  else if(fn.includes('masterfile')||fn.includes('master'))slot='master';
  else if(fn.includes('adjustment')||fn.includes('onetimeadj')||fn.includes('importadj'))slot='adj';
  else if(fn.includes('attendance')||fn.includes('attend'))slot='attend';
  else if(fn.includes('previous')||fn.includes('prev'))slot='prev';
  else if(fn.includes('current')||fn.includes('curr')||fn.includes('payrollsummary')||fn.includes('payrollregister')||fn.includes('payroll'))slot='curr';
  if(!slot){
    const order=['instr','master','prev','curr','adj','attend','adjsum','loansum'];
    slot=order.find(k=>!vFiles[k])||'instr';
  }
  loadVFile(file,slot);
}
