let bulkData=[];
function handleBulkUpload(e){
  const f=e.target.files[0];if(!f)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    try{
      const wb=XLSX.read(ev.target.result,{type:'array'});
      const ws=wb.Sheets[wb.SheetNames[0]];
      const rows=XLSX.utils.sheet_to_json(ws,{defval:''});
      if(!rows.length){showBulkError('File is empty or has no data rows.');return;}
      // Expected columns (case-insensitive): Client Name, Month, Period, Payout, Processor, Auditor, Team
      const colMap={};
      const firstRow=rows[0];
      const normalize=s=>String(s||'').toLowerCase().replace(/[^a-z]/g,'');
      Object.keys(firstRow).forEach(k=>{
        const n=normalize(k);
        if(n.includes('clientname')||n.includes('client'))colMap.name=k;
        else if(n==='month')colMap.month=k;
        else if(n.includes('period'))colMap.period=k;
        else if(n.includes('payout'))colMap.payout=k;
        else if(n.includes('processor'))colMap.processor=k;
        else if(n.includes('auditor'))colMap.auditor=k;
        else if(n.includes('team'))colMap.team=k;
      });
      if(!colMap.name){showBulkError('Could not find "Client Name" column. Please use the template.');return;}
      hideBulkError();
      bulkData=rows.map(r=>({
        name:String(r[colMap.name]||'').trim(),
        month:colMap.month?String(r[colMap.month]||'').trim():'',
        period:colMap.period?String(r[colMap.period]||'').trim():'',
        payout:colMap.payout?String(r[colMap.payout]||'').trim():'',
        processor:colMap.processor?String(r[colMap.processor]||'').trim():'',
        auditor:colMap.auditor?String(r[colMap.auditor]||'').trim():'',
        team:colMap.team?String(r[colMap.team]||'Team A').trim():'Team A',
      })).filter(r=>r.name);
      if(!bulkData.length){showBulkError('No valid client rows found.');return;}
      // Render preview
      const preview=document.getElementById('bulkPreview');
      const title=document.getElementById('bulkPreviewTitle');
      const table=document.getElementById('bulkPreviewTable');
      const note=document.getElementById('bulkPreviewNote');
      title.textContent=`${bulkData.length} client${bulkData.length>1?'s':''} found — preview (first 5):`;
      const cols=['name','month','period','payout','processor','auditor','team'];
      const hdrs=['Client Name','Month','Period','Payout','Processor','Auditor','Team'];
      table.innerHTML='<tr>'+hdrs.map(h=>`<th style="padding:6px 8px;background:#f9fafb;text-align:left;font-size:10px;color:#6b7280;border-bottom:0.5px solid #e5e7eb;white-space:nowrap;">${h}</th>`).join('')+'</tr>'+
        bulkData.slice(0,5).map(r=>'<tr>'+cols.map(c=>`<td style="padding:6px 8px;border-bottom:0.5px solid #f3f4f6;font-size:11px;white-space:nowrap;">${r[c]||'\u2014'}</td>`).join('')+'</tr>').join('');
      note.textContent=bulkData.length>5?`+${bulkData.length-5} more rows`:'';
      preview.style.display='block';
      document.getElementById('bulkSaveBtn').disabled=false;
      document.getElementById('bulkSaveBtn').style.opacity='1';
      // Highlight drop zone
      document.getElementById('bulkZone').style.borderColor='#3ecf0e';
      document.getElementById('bulkZone').style.background='#f0fdf4';
    }catch(err){showBulkError('Could not read file: '+err.message);}
  };
  reader.readAsArrayBuffer(f);
}

function showBulkError(msg){
  document.getElementById('bulkError').style.display='block';
  document.getElementById('bulkErrorMsg').textContent=msg;
  document.getElementById('bulkPreview').style.display='none';
