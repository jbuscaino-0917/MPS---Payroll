      const mfIc=mfH.find(h=>normL(h).includes('employee id'));if(!mfIc)continue;
      mfR.forEach(r=>{
        const id=normL(norm(r[mfIc]||''));
        if(!id||id.length<2||normL(id).includes('sample'))return;
        if(!/[0-9]/.test(id))return;
        if(!mfRowMap.has(id))mfRowMap.set(id,r);
      });
    }
  }

  // Build instruction NH rows map keyed by normL(Employee No.)
  const nhInstrMap=new Map();
  (exportData.nhRows||[]).forEach(instrRow=>{
    const id=normL(getVal(instrRow,'Employee No.'));
    if(id&&id.length>=2&&/[0-9]/.test(id))nhInstrMap.set(id,instrRow);
  });

  // Use hcRows "added" entries as the source (same as New Hire List in Headcount tab)
  const nhIds=hcRows.filter(r=>{
    if(r.status!=='added')return false;
    const idl=normL(String(r.id||''));
    // Skip section header rows that leaked in (e.g. 'change in personal info', 'salary increase')
