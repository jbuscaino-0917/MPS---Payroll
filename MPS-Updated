// ─── ATTENDANCE SECTION RENDERER ──────────────────────────
function renderAttendanceSection(attValRows){
  const isLate=(t)=>{const l=(t||'').toLowerCase();return l.includes('minutes late')||l.includes('late')||l.includes('undertime');};
  const isAbsent=(t)=>{const l=(t||'').toLowerCase();return l.includes('absent');};

  const toHHMM=(v)=>{
    if(v===''||v===null||v===undefined)return'—';
    const n=parseFloat(v);if(isNaN(n))return String(v);
    const sign=n<0?'-':'';const abs=Math.abs(n);
    const h=Math.floor(abs);const m=Math.round((abs-h)*60);
    return sign+String(h).padStart(2,'0')+':'+String(m).padStart(2,'0');
  };
  const fmtLate=(v,t)=>{
    if(v===''||v===null||v===undefined)return'—';
    const n=parseFloat(v);if(isNaN(n))return String(v);
    // Minutes Late and Undertime are both stored as raw minutes
    return n+' min';
  };
  const fmtAbs=(v)=>{
    if(v===''||v===null||v===undefined)return'—';
    const n=parseFloat(v);return isNaN(n)?String(v):(n+' day'+(n!==1?'s':''));
  };

  const lateRows=attValRows.filter(r=>isLate(r.otType));
  const absRows=attValRows.filter(r=>isAbsent(r.otType));

  const lateOk=lateRows.filter(r=>r.status==='MATCHED');
  const lateIss=lateRows.filter(r=>r.status!=='MATCHED');
  const absOk=absRows.filter(r=>r.status==='MATCHED');
  const absIss=absRows.filter(r=>r.status!=='MATCHED');

  document.getElementById('att-late-count').textContent=lateRows.length||'0';
  document.getElementById('att-late-issues').textContent=lateIss.length||'0';
  document.getElementById('att-abs-count').textContent=absRows.length||'0';
  document.getElementById('att-abs-issues').textContent=absIss.length||'0';
  document.getElementById('cnt-att-late-ok').textContent=lateOk.length;
  document.getElementById('cnt-att-late-issues').textContent=lateIss.length;
  document.getElementById('cnt-att-abs-ok').textContent=absOk.length;
  document.getElementById('cnt-att-abs-issues').textContent=absIss.length;

  const statusBadge=(s)=>{
    if(s==='MATCHED')return'<span class="badge" style="background:#f0fdf4;color:#16a34a;">&#10003; Matched</span>';
    if(s==='MISSING IN REGISTER')return'<span class="badge" style="background:#fef2f2;color:#dc2626;">&#10007; Missing in register</span>';
    if(s==='MISSING IN INSTRUCTIONS')return'<span class="badge" style="background:#fef2f2;color:#dc2626;">&#10007; Missing in instructions</span>';
    if(s==='AMOUNT MISMATCH'||s==='INSTR vs REG MISMATCH')return'<span class="badge" style="background:#fffbeb;color:#d97706;">&#9888; Amount mismatch</span>';
    if(s==='ID NOT IN MASTERFILE')return'<span class="badge" style="background:#fef2f2;color:#dc2626;">&#10007; ID not in masterfile</span>';
    return`<span class="badge" style="background:#fef2f2;color:#dc2626;">${s}</span>`;
  };

  const lateRowHtml=(r)=>`<tr>
    <td style="font-size:11px;color:#6b7280;">${r.empId}</td>
    <td style="font-weight:600;font-size:12px;">${r.empName}</td>
    <td><span class="badge" style="background:#fffbeb;color:#d97706;">${r.otType}</span></td>
    <td style="font-size:12px;">${fmtLate(r.instrHrs,r.otType)}</td>
    <td style="font-size:12px;">${fmtLate(r.regHrs,r.otType)}</td>
    <td>${statusBadge(r.status)}</td></tr>`;

  const absRowHtml=(r)=>`<tr>
    <td style="font-size:11px;color:#6b7280;">${r.empId}</td>
    <td style="font-weight:600;font-size:12px;">${r.empName}</td>
    <td><span class="badge" style="background:#fef2f2;color:#dc2626;">${r.otType}</span></td>
    <td style="font-size:12px;">${fmtAbs(r.instrHrs)}</td>
    <td style="font-size:12px;">${fmtAbs(r.regHrs)}</td>
    <td>${statusBadge(r.status)}</td></tr>`;

  document.querySelector('#tbl-att-late-ok tbody').innerHTML=lateOk.length
    ?lateOk.map(lateRowHtml).join('')
    :`<tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:12px;">No matched late/undertime entries</td></tr>`;
  document.querySelector('#tbl-att-late-issues tbody').innerHTML=lateIss.length
    ?lateIss.map(lateRowHtml).join('')
    :`<tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:12px;">&#10003; No late/undertime issues</td></tr>`;
  document.querySelector('#tbl-att-abs-ok tbody').innerHTML=absOk.length
    ?absOk.map(absRowHtml).join('')
    :`<tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:12px;">No matched absent entries</td></tr>`;
  document.querySelector('#tbl-att-abs-issues tbody').innerHTML=absIss.length
    ?absIss.map(absRowHtml).join('')
    :`<tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:12px;">&#10003; No absent issues</td></tr>`;

  document.getElementById('attSection').style.display='block';
}

// ─── PAYROLL COMPARISON (Summary of Changes) ──────────────
function buildPayrollComparison(pWB, cWB){

  // Columns to always exclude — info/rate/time fields, not direct pay amounts
  const SKIP_COL_PATTERNS=[
    'position','department','date hired','employment status','bank account','cost center',
    'gender','work days per year','(hh:mm)','hh:mm','gross/day','basic/hr'
  ];

  // Row-level filter: reject Sub Total, Total, Department rows and header repeats
  const isDataRow=(id)=>{
    if(!id||id.length<2)return false;
    const l=normL(id);
    if(l==='sub total'||l==='total'||l.startsWith('department')||l.startsWith('dept'))return false;
    if(ID_KEYS.some(k=>l===k||l.startsWith(k)))return false;
    return true;
  };

  // Decide if a column header should be treated as a pay column
  const isPayCol=(h,ic,nc)=>{
    if(!h||!h.trim())return false;
    if(normL(h)===normL(ic))return false;
    if(nc&&normL(h)===normL(nc))return false;
    const hl=normL(h);
    if(SKIP_COL_PATTERNS.some(p=>hl.includes(p)))return false;
    return true;
  };

  // Parse a cell value strictly to a pay number.
  // Rejects: time values (04:30), text (Active, Male, dates), returns null for non-numeric.
  const toNum=(v)=>{
    if(v===''||v==null)return null;
    const s=String(v).trim();
    if(!s)return null;
    if(/^\d{1,3}:\d{2}$/.test(s))return null;
    if(/[a-zA-Z]/.test(s))return null;
    if(/^\//.test(s)||s.includes('/'))return null;
    const n=parseFloat(s.replace(/,/g,''));
    return isNaN(n)?null:n;
  };

  // Build a Map<employeeId, {name, cols: Map<colName, number>}> from a workbook
  function extractRegister(wb){
    const empMap=new Map();
    for(const sn of wb.SheetNames){
      if(skipTab(sn))continue;
      const ws=wb.Sheets[sn];
      if(!ws||!ws['!ref'])continue;
      const hr=findHdr(ws,ID_KEYS);
      if(hr<0)continue;
      const{headers,rows}=sheetRows(ws,hr);
      const ic=findIdCol(headers);
      const nc=findNameCol(headers);
      if(!ic)continue;
      const payCols=headers.filter(h=>isPayCol(h,ic,nc));
      for(const row of rows){
        const id=norm(row[ic]);
        if(!isDataRow(id))continue;
        const name=nc?norm(row[nc]):'\u2014';
        if(!empMap.has(id))empMap.set(id,{name,cols:new Map()});
        const emp=empMap.get(id);
        if(emp.name==='\u2014'&&name!=='\u2014')emp.name=name;
        for(const h of payCols){
          const num=toNum(row[h]);
          if(num===null)continue;
          emp.cols.set(h,(emp.cols.get(h)||0)+num);
        }
      }
    }
    return empMap;
  }

  const prevMap=extractRegister(pWB);
  const currMap=extractRegister(cWB);

  // Preserve column order: current register first, then any extras from previous
  const colOrder=[];
  const colSeen=new Set();
  const addCols=(map)=>{map.forEach(e=>{e.cols.forEach((_,k)=>{if(!colSeen.has(k)){colSeen.add(k);colOrder.push(k);}});});};
  addCols(currMap);addCols(prevMap);

  const allIDs2=new Set([...prevMap.keys(),...currMap.keys()]);
  const rows=[];

  for(const id of allIDs2){
    const prevEmp=prevMap.get(id);
    const currEmp=currMap.get(id);
    const name=((currEmp||prevEmp)&&(currEmp||prevEmp).name)||'\u2014';
    const isAdded=!prevEmp&&!!currEmp;
    const isRemoved=!!prevEmp&&!currEmp;
    for(const col of colOrder){
      const prevVal=prevEmp&&prevEmp.cols.get(col)||null;
      const currVal=currEmp&&currEmp.cols.get(col)||null;
      if(prevVal===null&&currVal===null)continue;
      const p=prevVal||0;
      const c2=currVal||0;
      const variance=parseFloat((c2-p).toFixed(2));
      if(variance===0)continue;
      rows.push({
        'Employee ID':id,
        'Fullname':name,
        'Description Header':col,
        'Current':currVal!==null?parseFloat(c2.toFixed(2)):'',
        'Previous':prevVal!==null?parseFloat(p.toFixed(2)):'',
        'Variance':variance,
        'Remarks':isAdded?'NEWLY ADDED':isRemoved?'REMOVED':'WITH CHANGES'
      });
    }
  }

  rows.sort((a,b)=>{
    const idCmp=String(a['Employee ID']).localeCompare(String(b['Employee ID']),undefined,{numeric:true});
    if(idCmp!==0)return idCmp;
    return String(a['Description Header']).localeCompare(String(b['Description Header']));
  });

  return rows;
}
function normalizeEEStatus2(v){
  const vl=v.toLowerCase().replace(/[^a-z]/g,'');
  if(vl==='probi'||vl==='probationary'||vl==='probation')return 'probationary';
  if(vl==='active')return 'active';
  if(vl==='inactive')return 'inactive';
  if(vl==='onleave')return 'onleave';
  if(vl==='terminated'||vl==='terminate')return 'terminated';
  if(vl==='contractual'||vl==='contract')return 'contractual';
  if(vl==='endofcontract'||vl==='eoc')return 'endofcontract';
  if(vl==='regularized'||vl==='regular')return 'regular';
  return v.toLowerCase().trim();
}
